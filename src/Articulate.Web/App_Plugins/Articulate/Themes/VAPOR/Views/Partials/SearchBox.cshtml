@model IMasterModel

@if (Model.HasSearchRoute())
{
    <div class="articulate-search">
        <form method="get" action="@Model.ArticulateSearchUrl()" role="search">
            <label for="search-term" class="sr-only">Search</label>
            <input type="search" id="search-term" name="term" placeholder="Search..." aria-label="Search articles" />
            <button type="submit" aria-label="Submit search">
                <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
                <span class="sr-only">Search</span>
            </button>
        </form>
    </div>
}
