@model PostModel
@{
    var categories = Model.Categories.ToList();
    var tags = Model.Tags.ToList();
}

@if (tags.Count > 0 || categories.Count > 0)
{
    <div class="post-meta tags">

        @if (categories.Count > 0)
        {
            <div>
                Categories

                @for (int i = 0; i < categories.Count; i++)
                {
                    var category = categories[i];
                    <a href="@Model.ArticulateCategoryUrl(category)">@category</a>
                    if (i < categories.Count - 1)
                    {
                        <span>, </span>
                    }
                }
            </div>
        }

        @if (tags.Count > 0)
        {
            <div>
                Posted in

                @Model.ListTags(
                @<a href="@Model.ArticulateTagUrl(item)">@item</a>)

            </div>
        }
    </div>
}
