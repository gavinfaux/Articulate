@model PostModel
@{
    Layout = "Master.cshtml";
    ViewBag.CssBodyClass = "post-template";
}

@section header
{
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/prismjs@1.30.0/themes/prism.min.css"
        integrity="sha256-ko4j5rn874LF8dHwW29/xabhh8YBleWfvxb8nQce4Fc=" crossorigin="anonymous" media="all">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.38/dist/katex.min.css" integrity="sha256-RY5cj+WCt7sIKd7ocDoL1HSUDQ7IMt+1RVhHRVS2MJg=" crossorigin="anonymous" media="all">
}

<!--- TEMPLATE FOR BLOG POST --->

<div class="container">

    <!-- HEADER COLUMN --->
    <div class="header-col">
        <header>
            @await Html.PartialAsync("Header", Model)
        </header>
    </div>


    <!--- MAIN COLUMN --->
    <div class="main-col">
        <main>
            <div class="post-entry">
                <!--- POST CONTENT --->

                <article role="article" itemscope itemtype="http://schema.org/Article" class="postlistArticle">
                    <h1 class="post-title">@Model.Name</h1>

                    @Model.AuthorCitation()

                    <time datetime="@Model.PublishedDate.ToString("yyyy-MM-dd")" itemprop="datePublished">
                        <span class="datetime-full">@Model.PublishedDate.ToString("dd.MM.yyyy")</span>
                    </time>

                    <div class="post-info">
                        @if (Model.Tags.Any())
                        {
                            <div class="tags">
                                <i class="fa-solid fa-tags fa-lg"></i>
                                @await Html.PartialAsync("PostTags", Model)
                            </div>
                        }
                    </div>
                    <div class="hrule"></div>
                    <div class="postContent">
                        @if (!string.IsNullOrWhiteSpace(Model.CroppedPostImageUrl))
                        {
                            @if (Uri.TryCreate(Model.CroppedPostImageUrl, UriKind.RelativeOrAbsolute, out var imgUri) &&
                                                    (!imgUri.IsAbsoluteUri || (imgUri.Scheme == "http" || imgUri.Scheme == "https")))
                            {
                                <img class="postImage" alt="@Model.Name" src="@Model.CroppedPostImageUrl" />
                            }
                        }
                        @Model.Body
                    </div>
                </article>

                <!--- Sharing Section --->
                @await Html.PartialAsync("Share", Model)

                <!--- Comment sections - using DISQUS as default --->
                @if (Model.EnableComments && Model.IsDisqusEnabled)
                {
                    @await Html.PartialAsync("CommentsDisqus", Model)
                }

            </div>
        </main>
        <footer>
            @await Html.PartialAsync("Footer", Model)
        </footer>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/prismjs@1.30.0/components/prism-core.min.js"
    integrity="sha256-bKrTFt2ZHyT4AE4LnBnAVctYKf9l6XP77kBvltgbjn4=" crossorigin="anonymous" defer></script>
<script src="https://cdn.jsdelivr.net/npm/prismjs@1.30.0/plugins/autoloader/prism-autoloader.min.js"
        integrity="sha256-AjM0J5XIbiB590BrznLEgZGLnOQWrt62s3BEq65Q/I0=" crossorigin="anonymous"
        data-autoloader-path="https://cdn.jsdelivr.net/npm/prismjs@1.30.0/components/" defer></script>
<script src="https://cdn.jsdelivr.net/npm/katex@0.16.38/dist/katex.min.js" integrity="sha256-G2hiT4+WhwSWAR3lRvrTOAWxEuHhwPf6Z17ea6pHE2w=" crossorigin="anonymous" defer></script>
<script src="https://cdn.jsdelivr.net/npm/katex@0.16.38/dist/contrib/auto-render.min.js" integrity="sha256-5TctGZvNrotN5x0PfOunKkuhJ3SifGCm8fd9A7MijuQ=" crossorigin="anonymous" defer></script>
<script src="https://cdn.jsdelivr.net/npm/mermaid@11.13.0/dist/mermaid.min.js" integrity="sha256-PiACvzM5B/rnwdaGC7x49dpBe8cLZPPSJoWBuguouWo=" crossorigin="anonymous" defer></script>

<!-- Katex and Mermaid Init -->
<script>
    document.addEventListener("DOMContentLoaded", function() {
      renderMathInElement(document.body, {
        delimiters: [
          {left: '$$', right: '$$', display: true},
          {left: '$', right: '$', display: false},
          {left: '\\(', right: '\\)', display: false},
          {left: '\\[', right: '\\]', display: true}
        ],
        throwOnError: false
      });
    mermaid.initialize({ startOnLoad: true });
    });
</script>
