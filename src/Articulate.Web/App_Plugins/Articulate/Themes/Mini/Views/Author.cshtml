@model AuthorModel
@{
    Layout = "Master.cshtml";
    ViewBag.CssBodyClass = "post-template";
}

@section Header
{
    @Model.AuthorRssFeed()
}

<!--- TEMPLATE FOR BLOG POST --->

<div class="container">

    <!-- HEADER COLUMN --->
    <div class="header-col">
        <header>
            @await Html.PartialAsync("Header", Model)
        </header>
    </div>


    <!--- MAIN COLUMN --->
    <div class="main-col">
        <main>
            <div class="post-entry">
                <!--- POST CONTENT --->

                <article role="article" itemscope itemtype="http://schema.org/Article" class="postlistArticle">
                    <h1 class="post-title">@Model.Name<a href="@Model.ArticulateAuthorRssUrl()" class="fa-solid fa-rss"></a></h1>

                    <div class="hrule"></div>
                    <div class="postContent">
                        @if (Model.Image is not null)
                        {
                            var imgUrl = Model.Image.GetCropUrl(cropAlias: "wide", preferFocalPoint: true, useCropDimensions: true);
                            <img class="postImage" alt="@Model.Name" src="@imgUrl" />
                        }
                        <p>
                            @Model.Bio
                        </p>
                        @if (Model.AuthorUrl is not null)
                        {
                            <p>
                                Website: <a href="@Model.AuthorUrl" rel="nofollow noopener noreferrer" target="_blank">@Model.AuthorUrl</a>
                            </p>
                        }
                    </div>
                </article>


            </div>
        </main>
        <footer>
            @await Html.PartialAsync("Footer", Model)
        </footer>
    </div>
</div>
