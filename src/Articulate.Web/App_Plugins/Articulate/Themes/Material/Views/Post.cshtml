@inherits UmbracoViewPage<PostModel>
@{
    Layout = "Master.cshtml";
    ViewBag.CssWrapperClass = "demo-blog--blogpost";
    var hasTagsRoute = Model.HasTagsRoute();
    var hasCategoriesRoute = Model.HasCategoriesRoute();
}

@section header
{
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/prismjs@1.30.0/themes/prism.min.css" integrity="sha256-ko4j5rn874LF8dHwW29/xabhh8YBleWfvxb8nQce4Fc=" crossorigin="anonymous" media="all">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.38/dist/katex.min.css" integrity="sha256-RY5cj+WCt7sIKd7ocDoL1HSUDQ7IMt+1RVhHRVS2MJg=" crossorigin="anonymous" media="all">
}

<div class="demo-back">
    <a class="mdl-button mdl-js-button mdl-js-ripple-effect mdl-button--icon" href="@Model.RootBlogNode.Url()" title="go back" role="button">
        <i class="material-icons" role="presentation">arrow_back</i>
    </a>
</div>
<div class="demo-blog__posts mdl-grid">
    <div class="mdl-card mdl-shadow--4dp mdl-cell mdl-cell--12-col">

        @await Html.PartialAsync("PostImageHeader", Model)

        <div class="mdl-color-text--grey-700 mdl-card__supporting-text meta">
            @await Html.PartialAsync("AuthorInfo", Model)
            <div class="section-spacer"></div>
            @if (Model.EnableComments && Model.IsDisqusEnabled)
            {
                <div class="meta__favorites">
                    <a class="mdl-color-text--grey-700" href="@Model.Url()#disqus_thread" data-disqus-identifier="@Model.Key"></a>
                    <a class="mdl-color-text--grey-700" href="@Model.Url()#disqus_thread" data-disqus-identifier="@Model.Key"><i class="material-icons" role="presentation">comment</i></a>
                    <span class="visuallyhidden">comments</span>
                </div>
            }
        </div>
        <div class="mdl-color-text--grey-700 mdl-card__supporting-text post-content">
            @Model.Body
        </div>
        <div class="mdl-color-text--grey-700 mdl-card__supporting-text meta">
            <div class="post-tags">
                <div>
                    <span>Tags:</span>
                    @if (hasTagsRoute)
                    {
                        @Model.ListTags(@<a class="mdl-color-text--accent" href="@Model.ArticulateTagUrl(item)">@item</a>)
                    }
                    else
                    {
                        @Model.ListTags(@<span class="mdl-color-text--accent">@item</span>)
                    }
                </div>
                <div>
                    <span>Categories:</span>
                    @if (hasCategoriesRoute)
                    {
                        @Model.ListCategories(@<a class="mdl-color-text--accent" href="@Model.ArticulateCategoryUrl(item)">@item</a>, " | ")
                    }
                    else
                    {
                        @Model.ListCategories(@<span class="mdl-color-text--accent">@item</span>, " | ")
                    }
                </div>
            </div>
        </div>
        @if (Model.EnableComments && Model.IsDisqusEnabled)
        {
            <div class="mdl-card__supporting-text mdl-color--grey-200">


                @await Html.PartialAsync("CommentsDisqus", Model)

            </div>

        }


    </div>

    @{
        var next = Model.Next();
        var prev = Model.Previous();

    }
    <nav class="demo-nav mdl-color-text--grey-50 mdl-cell mdl-cell--12-col">
        @if (next is not null)
        {
            <a href="@next.Url()" class="demo-nav__button">
                <span class="mdl-button mdl-js-button mdl-js-ripple-effect mdl-button--icon mdl-color--white mdl-color-text--grey-900" role="presentation">
                    <i class="material-icons">arrow_back</i>
                </span>
                Newer
            </a>
        }
        <div class="section-spacer"></div>
        @if (prev is not null)
        {
            <a href="@prev.Url()" class="demo-nav__button">
                Older
                <span class="mdl-button mdl-js-button mdl-js-ripple-effect mdl-button--icon mdl-color--white mdl-color-text--grey-900" role="presentation">
                    <i class="material-icons">arrow_forward</i>
                </span>
            </a>
        }
    </nav>
</div>

<script src="https://cdn.jsdelivr.net/npm/prismjs@1.30.0/components/prism-core.min.js" integrity="sha256-bKrTFt2ZHyT4AE4LnBnAVctYKf9l6XP77kBvltgbjn4=" crossorigin="anonymous" defer></script>
<script src="https://cdn.jsdelivr.net/npm/prismjs@1.30.0/plugins/autoloader/prism-autoloader.min.js" integrity="sha256-AjM0J5XIbiB590BrznLEgZGLnOQWrt62s3BEq65Q/I0=" crossorigin="anonymous" data-autoloader-path="https://cdn.jsdelivr.net/npm/prismjs@1.30.0/components/" defer></script>
<script src="https://cdn.jsdelivr.net/npm/katex@0.16.38/dist/katex.min.js" integrity="sha256-G2hiT4+WhwSWAR3lRvrTOAWxEuHhwPf6Z17ea6pHE2w=" crossorigin="anonymous" defer></script>
<script src="https://cdn.jsdelivr.net/npm/katex@0.16.38/dist/contrib/auto-render.min.js" integrity="sha256-5TctGZvNrotN5x0PfOunKkuhJ3SifGCm8fd9A7MijuQ=" crossorigin="anonymous" defer></script>
<script src="https://cdn.jsdelivr.net/npm/mermaid@11.13.0/dist/mermaid.min.js" integrity="sha256-PiACvzM5B/rnwdaGC7x49dpBe8cLZPPSJoWBuguouWo=" crossorigin="anonymous" defer></script>

<!-- Katex and Mermaid Init -->
<script>
    document.addEventListener("DOMContentLoaded", function() {
      renderMathInElement(document.body, {
        delimiters: [
          {left: '$$', right: '$$', display: true},
          {left: '$', right: '$', display: false},
          {left: '\\(', right: '\\)', display: false},
          {left: '\\[', right: '\\]', display: true}
        ],
        throwOnError: false
      });
    mermaid.initialize({ startOnLoad: true });
    });
</script>
