@model MarkdownEditorInitModel

@{
    Layout = null;
    if (Model?.ArticulateBlogNode is null)
    {
        throw new InvalidOperationException("Missing ArticulateBlogNode parameter.");
    }
    if (Model?.EditorPostUrl is null)
    {
        throw new InvalidOperationException("Missing EditorPostUrl parameter.");
    }
    if (string.IsNullOrWhiteSpace(Model?.BackOfficeClientId))
    {
        throw new InvalidOperationException("Missing BackOfficeClientId parameter.");
    }
}

<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Articulate - Create New Post</title>
    <link rel="preconnect" href="https://code.getmdl.io">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preconnect" href="https://cdn.jsdelivr.net">
    <link rel="stylesheet" href="https://code.getmdl.io/1.3.0/material.pink-blue.min.css" fetchpriority="high">
    <link href="~/App_Plugins/Articulate/MarkdownEditor/assets/css/md-editor.css" rel="stylesheet" fetchpriority="high">


    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tiny-markdown-editor@0.2.0/dist/tiny-mde.min.css" integrity="sha256-MZ1zddO2Et4HONRzfJKJ1vC/Ecj9JIa3MI2GYCX2l5Y=" crossorigin="anonymous" media="print" onload="this.media='all'">
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet" media="print" onload="this.media='all'">

    <style>
        [x-cloak] {
            display: none !important;
        }
        .articulate-diagnostics {
            max-width: 720px;
            margin: 48px auto;
        }
        .articulate-dev-bypass {
            margin-bottom: 24px;
        }
    </style>
</head>
<body x-data="markdownEditor"
      x-init="init"
      x-cloak
      data-articulate-blog-node="@Model.ArticulateBlogNode"
      data-auth-url="@MarkdownEditorInitModel.AuthorizeUrl"
      data-auth-end-url="@MarkdownEditorInitModel.EndSessionUrl"
      data-token-url="@MarkdownEditorInitModel.TokenUrl"
      data-current-user-url="@MarkdownEditorInitModel.CurrentUserUrl"
      data-editor-post-url="@Model.EditorPostUrl"
      data-oauth-client-id="@Model.BackOfficeClientId"
      data-backoffice-logged-in="@Model.IsBackOfficeLoggedIn.ToString().ToLowerInvariant()">
    <div class="mdl-layout mdl-js-layout mdl-layout--fixed-header">
        <header class="mdl-layout__header">
            <div class="mdl-layout__header-row">
                <span class="mdl-layout-title" x-text="caption"></span>
                <div class="mdl-layout-spacer"></div>
                <nav class="mdl-navigation" x-show="currentUser">
                    <button type="button"
                            class="mdl-chip mdl-chip--contact"
                            @@click.prevent="logout"
                            @@keydown.enter.prevent="logout"
                            @@keydown.space.prevent="logout">
                        <span class="mdl-chip__contact mdl-color--blue mdl-color-text--white" x-text="userInitials"></span>
                        <span class="mdl-chip__text">Logout</span>
                        <span class="mdl-chip__action" aria-hidden="true"><i class="material-icons">logout</i></span>
                    </button>
                </nav>
                <div x-show="isLoading" class="mdl-spinner mdl-js-spinner is-active"></div>
            </div>
        </header>

        <main class="mdl-layout__content">
            <div class="page-content">
                <!-- Login View -->
                <template x-if="isLoginStep">
                    <div class="mdl-card mdl-shadow--2dp fill-height" x-ref="loginView">
                        <div class="mdl-card__supporting-text">
                            <p class="mdl-typography--body-1" x-text="loginNotice"></p>
                            <div class="btn-raised-right">
                                <button type="button"
                                        class="mdl-button mdl-js-button mdl-button--raised mdl-js-ripple-effect mdl-button--accent"
                                        @@click="startLogin"
                                        :disabled="isLoading">
                                    Continue to login
                                </button>
                            </div>
                        </div>
                    </div>
                </template>

                <!-- Editor View -->
                <template x-if="isEditorStep">
                    <div x-ref="editorView" class="mdl-card mdl-shadow--2dp fill-height">
                        <div class="mdl-card__supporting-text">
                            <div class="mdl-textfield mdl-js-textfield fixed" :class="titleErrorClass">
                                <input class="mdl-textfield__input" type="text" id="title" :value="postTitle" @@input="updatePostTitle" required>
                                <label class="mdl-textfield__label" for="title">Title...</label>
                            </div>
                            <div class="mdl-textfield mdl-js-textfield md-input">
                                <textarea x-ref="editor" id="editor" class="mdl-textfield__input" placeholder="## Start writing your post here..."></textarea>
                            </div>
                        </div>
                    </div>
                </template>

                <!-- Optional View -->
                <template x-if="isOptionalStep">
                    <div x-ref="optionalView" class="mdl-card mdl-shadow--2dp fill-height">
                        <div class="mdl-card__supporting-text">
                            <div class="mdl-textfield mdl-js-textfield">
                                <label class="mdl-textfield__label" for="tags">Tags...</label>
                                <input class="mdl-textfield__input" type="text" id="tags" :value="postTags" @@input="updatePostField">
                            </div>

                            <div class="mdl-textfield mdl-js-textfield">
                                <label class="mdl-textfield__label" for="categories">Categories...</label>
                                <input class="mdl-textfield__input" type="text" id="categories" :value="postCategories" @@input="updatePostField">
                            </div>

                            <div class="mdl-textfield mdl-js-textfield">
                                <label class="mdl-textfield__label" for="excerpt">Excerpt...</label>
                                <textarea class="mdl-textfield__input" id="excerpt" rows="3" :value="postExcerpt" @@input="updatePostField"></textarea>
                            </div>

                            <div class="mdl-textfield mdl-js-textfield">
                                <label class="mdl-textfield__label" for="slug">Slug...</label>
                                <input class="mdl-textfield__input" type="text" id="slug" :value="postSlug" @@input="updatePostField">
                            </div>
                        </div>
                    </div>
                </template>
                <!-- Success View -->
                <template x-if="isSuccessStep">
                    <div x-ref="successView" class="mdl-card mdl-shadow--2dp fill-height">
                        <div class="mdl-card__supporting-text">
                            <div class="mdl-progress mdl-js-progress mdl-progress__indeterminate" x-show="isLoading"></div>
                            <div x-show="isNotLoading">
                                <h3>Success!</h3>
                                <p>Your post has been published. Click below to view it.</p>
                            </div>
                        </div>
                        <div class="mdl-card__actions mdl-card--border" x-show="isNotLoading">
                            <a class="mdl-button mdl-js-button mdl-button--raised mdl-button--accent"
                               :href="successUrl" target="_blank" rel="noopener">
                                View Post
                            </a>
                            <button type="button"
                                    class="mdl-button mdl-js-button mdl-button--primary"
                                    @@click="resetForNewPost">
                                Create Another Post
                            </button>
                        </div>
                    </div>
                </template>
            </div>
        </main>
    </div>

    <div class="btn-fab-right">
        <button x-show="isOptionalStep" @@click="goToEditorStep" style="transform: rotate(180deg);" class="mdl-button mdl-js-button mdl-button--fab mdl-js-ripple-effect mdl-button--accent material-icons" title="Previous">forward</button>
        <button x-show="canShowNextButton" :disabled="disableNextButton" @@click="goToOptionalStep" class="mdl-button mdl-js-button mdl-button--fab mdl-js-ripple-effect mdl-button--accent material-icons" title="Next">forward</button>
        <button x-show="canShowPublishButton" :disabled="disablePublishButton" @@click="handlePublish" class="mdl-button mdl-js-button mdl-button--fab mdl-js-ripple-effect mdl-button--accent material-icons" title="Publish">done</button>
    </div>

    <!-- Hidden file inputs -->
    <div class="hidden-insert-file">
        <input x-ref="imageUpload" type="file" accept="image/jpeg,image/png,image/gif" @@change="handleImageUpload">
        <input x-ref="cameraUpload" type="file" accept="image/jpeg,image/png,image/gif" capture="user" @@change="handleImageUpload">
    </div>

    <!-- Floating Action Buttons -->
    <div class="btn-fab-left">
        <button x-show="isEditorStep" @@click="triggerImageUpload" class="mdl-button mdl-js-button mdl-button--fab mdl-js-ripple-effect mdl-button--colored material-icons" title="Upload Image">photo</button>
        <button x-show="isEditorStep" @@click="triggerCamera" class="mdl-button mdl-js-button mdl-button--fab mdl-js-ripple-effect mdl-button--colored material-icons" title="Use Camera">photo_camera</button>
    </div>

    <!-- Enhanced Global Error Message -->
    <template x-if="errorDetails">
        <div class="articulate-error-box" x-transition>
            <strong x-text="errorDetails.title"></strong>
            <template x-if="hasErrorDetails">
                <ul class="articulate-error-list">
                    <template x-for="(detail, index) in errorDetails.details" :key="index">
                        <li x-text="detail"></li>
                    </template>
                </ul>
            </template>
        </div>
    </template>


    <script defer src="https://code.getmdl.io/1.3.0/material.min.js" crossorigin="anonymous"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/tiny-markdown-editor@0.2.0/dist/tiny-mde.min.js" integrity="sha256-3RX+4eonZtpTV5BuscEas9t44jhaxeOaQ9T/tP8SeC0=" crossorigin="anonymous"></script>

    <!-- TODO: Bundle with parcel/webpack or other, we must load our Alpine module before Alpine.js -->
    <script defer src="~/App_Plugins/Articulate/MarkdownEditor/assets/js/config.js?d=1" type="module"></script>
    <script defer src="~/App_Plugins/Articulate/MarkdownEditor/assets/js/error-formatter.js?d=1" type="module"></script>
    <script defer src="~/App_Plugins/Articulate/MarkdownEditor/assets/js/uiService.js?d=1" type="module"></script>
    <script defer src="~/App_Plugins/Articulate/MarkdownEditor/assets/js/authService.js?d=1" type="module"></script>
    <script defer src="~/App_Plugins/Articulate/MarkdownEditor/assets/js/apiService.js?d=1" type="module"></script>
    <script defer src="~/App_Plugins/Articulate/MarkdownEditor/assets/js/md-editor.js?d=1" type="module"></script>

<script defer src="https://cdn.jsdelivr.net/npm/@@alpinejs/csp@3.14.9/dist/cdn.min.js" integrity="sha256-ggvJUDh0AkBX2iRNwwwhMBVIMp65oA55N+kcTTkIsnM=" crossorigin="anonymous"></script>

    <!-- Critical Error Dialog -->
    <dialog class="mdl-dialog" x-ref="criticalErrorDialog" @@close="handleDialogClose">
        <h4 class="mdl-dialog__title" x-text="dialog.title"></h4>
        <div class="mdl-dialog__content">
            <p x-text="dialog.message"></p>
        </div>
        <div class="mdl-dialog__actions">
            <button type="button" class="mdl-button" @@click="confirmCriticalError" x-text="dialog.buttonText"></button>
        </div>
    </dialog>

</body>
</html>
