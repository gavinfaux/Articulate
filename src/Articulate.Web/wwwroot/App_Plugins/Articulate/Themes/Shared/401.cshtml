@{
    Layout = null; // Standalone HTML for plugin-scoped 401; does not depend on theme layout or model
    Context.Response.StatusCode = 401;
}
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Unauthorized</title>
  <style>
    :root { color-scheme: light dark; }
    body{font-family:system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif;margin:2rem;line-height:1.5;color:#222}
    .box{max-width:720px;margin:0 auto;border:1px solid #e5e7eb;border-radius:8px;padding:1.25rem;background:#fff}
    h1{font-size:1.5rem;margin:0 0 .5rem 0}
    p{margin:.5rem 0}
    a.button{display:inline-block;margin-top:1rem;padding:.5rem .875rem;border-radius:6px;background:#2563eb;color:#fff;text-decoration:none}
    a.button:hover{background:#1d4ed8}
  </style>
</head>
<body>
  <div class="box" role="alert" aria-live="polite">
    <h1>Back office sign-in required</h1>
    <p>You must be signed in to the Umbraco back office to access this page.</p>
    <p>Open the back office in a new tab, sign in, then return here.</p>
    <p><a class="button" href="/umbraco/">Go to Umbraco back office</a></p>
  </div>
</body>
</html>
