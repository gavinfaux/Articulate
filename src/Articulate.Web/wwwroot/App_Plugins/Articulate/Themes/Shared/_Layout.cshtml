@model IMasterModel
@*
  THEME CONTRACT (Shared Base)
  - Naming: Use BEM-like class names for structure that themes can safely target.
    Example blocks/elements/modifiers:
      .site-header
      .site-header__brand
      .post-list
      .post-preview
      .post-preview--featured (modifier)
      .post-preview__title (element)
  - Optional sections (slots):
      @RenderSection("Header", required: false)
      @RenderSection("Sidebar", required: false)
      @RenderSection("Scripts", required: false)
    Child themes may define any of these sections if they need to inject content.
  - Assets: Shared provides minimal base CSS (reset/utility kept light). Child themes import/override.
*@
<!DOCTYPE html>
<html lang="en">
<head>
    @Model.GoogleAnalyticsTracking()
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@Model.PageTitle</title>
    @Model.MetaTags()
    @Html.SocialMetaTags(Model)
    @Model.AdvertiseWeblogApi()
    @Model.RssFeed()
    @Model.RenderOpenSearch()

    @* Theme-first assets: Head *@
    @await Html.PartialAsync("HeadAssets")

    @RenderSection("Header", required: false)
</head>
<body class="articulate">
    @Model.GoogleAnalyticsNoScript()
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <header class="site-header" role="banner">
        @if (!Model.BlogLogo.IsNullOrWhiteSpace())
        {
            <a class="site-logo" href="@Model.ArticulateRootUrl()" title="Blog Home">
                <img src="@Model.BlogLogo" alt="@Model.BlogTitle logo" />
            </a>
        }
        <h1 class="site-title"><a href="@Model.ArticulateRootUrl()">@Model.BlogTitle</a></h1>
        <p class="site-description">@Model.BlogDescription</p>
        @await Html.PartialAsync("Menu", Model)
        @await Html.PartialAsync("HeaderDescription", Model)

        @RenderSection("Header", required: false)
    </header>

    <main id="main-content" role="main" tabindex="-1">
        @RenderBody()
        @RenderSection("Sidebar", required: false)
    </main>

    <footer class="site-footer">
        @await Html.PartialAsync("FooterDescription", Model)
        <p class="copyright">&copy; @DateTime.Now.ToString("yyyy") @Model.BlogTitle</p>
    </footer>

    @* Theme-first assets: Foot *@
    @await Html.PartialAsync("FootAssets")

    @RenderSection("Scripts", required: false)
</body>
</html>
