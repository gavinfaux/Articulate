@model TagListModel

<section class="tags">
    <header>
        <h1>@Model.Name</h1>
        <p class="post-meta">@(Model.Tags?.Count() ?? 0) tag groups</p>
    </header>

    @* Tag cloud example using Shared partial and built-in TagCloud helper *@
    @await Html.PartialAsync("TagCloud", Model.Tags)

    @if (Model.Tags is null || !Model.Tags.Any())
    {
        <p>No tags found.</p>
    }
    else
    {
        <ul class="tag-list">
            @foreach (var tag in Model.Tags)
            {
                <li>
                    <a href="@tag.TagUrl">@tag.TagName</a> <span>(@tag.PostCount)</span>
                </li>
            }
        </ul>
    }
</section>
