@model PostModel
@using Articulate.Options
@using Microsoft.Extensions.Options
@inject IOptions<ArticulateOptions> ArticulateOpts
@*
Comments provider switch partial (Shared)
Usage:
- Set ViewData["CommentsProvider"] = "disqus" | "giscus";
- Or override this partial in your theme and hardcode your provider + config.

IMPORTANT:
- Replace placeholder values (shortnames, repo IDs, website IDs) with your own in a theme override.
- Consider moving secrets/config to appsettings or environment variables, not in views.
*@

@if (Model is not { EnableComments: true })
{
    return;
}

@{
    var configured = ArticulateOpts?.Value.DefaultCommentsProvider;
    var provider = (ViewData["CommentsProvider"] as string
    ?? configured
    ?? "placeholder").ToLowerInvariant();
}

<section id="comments" class="comments" role="region" aria-label="Comments">
    <h2 class="comments__title">Comments</h2>

    @switch (provider)
    {
        case "disqus":
            if (!string.IsNullOrWhiteSpace(ArticulateOpts?.Value.Disqus.Shortname))
            {
                <div id="disqus_thread"></div>
                <script>
                    var disqus_config = function () {
                        this.page.url = window.location.href;
                        this.page.identifier = '@Model.Id';
                    };
                    (function () {
                        var d = document, s = d.createElement('script');
                        var shortname = '@(ArticulateOpts?.Value.Disqus.Shortname!)';
                        s.src = 'https://' + shortname + '.disqus.com/embed.js';
                        s.setAttribute('data-timestamp', +new Date());
                        (d.head || d.body).appendChild(s);
                    })();
                </script>
                <noscript>Please enable JavaScript to view the comments powered by Disqus.</noscript>
            }
            else
            {
                <p class="comments__placeholder">Disqus is selected but not configured. Set <code>Articulate:Disqus:Shortname</code>
                    in appsettings or override this partial.</p>
            }
            break;

        case "giscus":
            if (!string.IsNullOrWhiteSpace(ArticulateOpts?.Value.Giscus.Repo) &&
            !string.IsNullOrWhiteSpace(ArticulateOpts.Value.Giscus.RepoId))
            {
                var g = ArticulateOpts.Value.Giscus;
                <script src="https://giscus.app/client.js" data-repo="@g.Repo" data-repo-id="@g.RepoId" data-category="@g.Category"
                    data-category-id="@g.CategoryId" data-mapping="@g.Mapping" data-strict="0"
                    data-reactions-enabled="@(g.ReactionsEnabled ? "1" : "0")" data-emit-metadata="@(g.EmitMetadata ? "1" : "0")"
                    data-input-position="@g.InputPosition" data-theme="@g.Theme" data-lang="@g.Lang" crossorigin="anonymous" async>
                    </script>
            }
            else
            {
                <p class="comments__placeholder">Giscus is selected but not configured. Set values under
                    <code>Articulate:Giscus</code> in appsettings or override this partial.</p>
            }
            break;

        default:
            <p class="comments__placeholder">
                Comments are enabled for this post. Set <code>ViewData["CommentsProvider"]</code>
                to <code>disqus</code> or <code>giscus</code>, or override <code>Partials/CommentsProvider.cshtml</code>
                in your theme to wire up a custom provider.
            </p>
            break;
    }
</section>
