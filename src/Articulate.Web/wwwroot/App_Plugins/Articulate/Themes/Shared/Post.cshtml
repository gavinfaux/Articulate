@{
#nullable enable
}
@model PostModel

<article class="post">
    <header>
        <h1 class="post-title">@Model.Name</h1>
        <p class="post-meta">
            <time datetime="@Model.PublishedDate.ToString("o")">
                @Model.PublishedDate.ToLocalTime().ToString("f", System.Globalization.CultureInfo.CurrentUICulture)
            </time>
        </p>
        @await Html.PartialAsync("PostTags", Model)
    </header>
    @await Html.PartialAsync("PostByline", Model)

    @if (Model.PostImage is not null)
    {
        <figure class="post-image">
            @{
                Umbraco.Cms.Core.Models.MediaWithCrops? postMedia = null;
                try { postMedia = Model.PostImage as Umbraco.Cms.Core.Models.MediaWithCrops; } catch { }
            }
            @if (postMedia is not null)
            {
                @await Html.PartialAsync("ResponsiveImage", postMedia, new Microsoft.AspNetCore.Mvc.ViewFeatures.ViewDataDictionary(ViewData)
                {
                    { "alt", Model.Name },
                    { "crop", "wide" },
                    { "sizes", "(min-width: 1024px) 1024px, 100vw" },
                    { "widths", "480,768,1024" }
                })
            }
            else
            {
                var wide = Model.CroppedPostImageUrl;
                <img src="@wide" alt="" />
            }
        </figure>
    }

    <section class="post-body prose">
        @Model.Body
    </section>

    @* Share actions (progressive enhancement) *@
    @await Html.PartialAsync("Share", Model)
</article>

@* Author summary card *@
@await Html.PartialAsync("AuthorCard", Model)

@* Prev/Next navigation between posts *@
@await Html.PartialAsync("PrevNext", Model)

@if (Model.EnableComments)
{
    @await Html.PartialAsync("CommentsProvider", Model)
}
