@using Articulate.Services
@using Microsoft.Extensions.DependencyInjection
@using Umbraco.Cms.Core
@using Microsoft.AspNetCore.Mvc.ViewEngines
@inject ICompositeViewEngine ViewEngine

@{
    // Default to Shared layout to preserve fallback behavior
    Layout = "_Layout.cshtml";

    // If the active theme has its own layout, prefer it
    var themeName = Context?.Items?["ThemeName"] as string;
    if (!string.IsNullOrWhiteSpace(themeName))
    {
        var themeLayoutPath = $"~/App_Plugins/Articulate/Themes/{themeName}/_Layout.cshtml";
        var canUseThemeLayout = ViewEngine.GetView(executingFilePath: null, viewPath: themeLayoutPath, isMainPage: false).Success;
        if (canUseThemeLayout)
        {
            Layout = themeLayoutPath;
        }
    }
}
