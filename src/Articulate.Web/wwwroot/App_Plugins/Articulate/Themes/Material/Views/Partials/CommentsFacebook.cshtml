@model PostModel

@*Facebook comments aren't responsive. Use at your own risk.*@

<div id="fb-root"></div>
<script>
    (function(d, s, id) {
      var js, fjs = d.getElementsByTagName(s)[0];
      if (d.getElementById(id)) return;
      js = d.createElement(s); js.id = id;
      js.src = "https://connect.facebook.net/en_US/sdk.js#xfbml=1&version=v19.0";
      js.integrity = "sha256-GENERATE_ACTUAL_HASH_HERE";
      js.crossOrigin = "anonymous";
      fjs.parentNode.insertBefore(js, fjs);
    }(document, 'script', 'facebook-jssdk'));</script><div class="fb-comments" data-href="@Model.Url(mode: UrlMode.Absolute)" data-numposts="5" data-colorscheme="light"></div>
