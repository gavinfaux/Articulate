@model PostModel

@if (Model.Tags.Any() || Model.Categories.Any())
{
    <div class="post-meta tags">

        @if (Model.Categories.Any())
        {
            <div>
                Categories

                @foreach (var category in Model.Categories)
                {
                    <a href="@Model.ArticulateCategoryUrl(category)">@category</a>
                    if (category != Model.Categories.Last())
                    {
                        <span>, </span>
                    }
                }
            </div>
        }

        @if (Model.Tags.Any())
        {
            var tags = Model.Tags.ToList();
            <div>
                Posted in

                @for (int i = 0; i < tags.Count; i++)
                {
                    var tag = tags[i];
                    <a href="@Model.ArticulateTagUrl(tag)">@tag</a>
                    if (i < tags.Count - 1)
                    {
                        <span>, </span>
                    }
                }
            </div>
        }
    </div>
}
