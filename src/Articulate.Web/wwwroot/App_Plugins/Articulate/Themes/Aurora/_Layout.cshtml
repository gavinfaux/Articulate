@model IMasterModel
@*
  Optional Sections (usage examples):
  - In a view, define:
      @section Sidebar { <aside>Theme-specific sidebar</aside> }
      @section Scripts { <script>/* page extras */</script> }
  - These are rendered below in <main> and before </body>.
*@
<!DOCTYPE html>
<html lang="en">
<head>
    @Model.GoogleAnalyticsTracking()
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@Model.PageTitle</title>
    @Model.MetaTags()
    @Html.SocialMetaTags(Model)
    @Model.AdvertiseWeblogApi()
    @Model.RssFeed()
    @Model.RenderOpenSearch()

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <link href="~/App_Plugins/Articulate/Themes/Shared/assets/css/base.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/App_Plugins/Articulate/Themes/Aurora/assets/css/reset.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/App_Plugins/Articulate/Themes/Aurora/assets/css/tokens.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/App_Plugins/Articulate/Themes/Aurora/assets/css/base.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/App_Plugins/Articulate/Themes/Aurora/assets/css/components.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/App_Plugins/Articulate/Themes/Aurora/assets/css/utilities.css" rel="stylesheet" asp-append-version="true" />

    @RenderSection("Header", required: false)
</head>
<body class="aurora">
    @Model.GoogleAnalyticsNoScript()
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <header class="site-header" role="banner">
        <div class="container">
            <div class="brand">
                @if (!Model.BlogLogo.IsNullOrWhiteSpace())
                {
                    <a class="site-logo" href="@Model.ArticulateRootUrl()" title="Blog Home">
                        <img src="@Model.BlogLogo" alt="@Model.BlogTitle logo" />
                    </a>
                }
                <h1 class="site-title"><a href="@Model.ArticulateRootUrl()">@Model.BlogTitle</a></h1>
                <p class="site-description">@Model.BlogDescription</p>
            </div>
            @await Html.PartialAsync("Menu", Model)
        </div>
    </header>

    <main id="main-content" class="container" role="main" tabindex="-1">
        @RenderBody()
        @RenderSection("Sidebar", required: false)
    </main>

    <footer class="site-footer">
        <div class="container">
            @await Html.PartialAsync("FooterDescription", Model)
            <p class="copyright">&copy; @DateTime.Now.ToString("yyyy") @Model.BlogTitle</p>
        </div>
    </footer>
    @RenderSection("Scripts", required: false)
</body>
</html>
