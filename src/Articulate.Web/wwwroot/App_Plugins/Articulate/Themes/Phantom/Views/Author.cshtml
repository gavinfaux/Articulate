@model AuthorModel
@{
    Layout = "Master.cshtml";
    ViewBag.CssBodyClass = "author-template";}

@section Header
{
    @Model.AuthorRssFeed()
}

<article class="post tag-ghost-tag">

    <h1 class="post-title">@Model.Name<a href="@Model.ArticulateAuthorRssUrl()" class="icon-rss"></a></h1>

    <section class="post-content">
        @if (Model.Image is not null)
        {
            var imgUrl = Model.Image.GetCropUrl("wide");
            <img class="postImage" alt="@Model.Name" src="@imgUrl" />
        }
        <p>@Model.Bio</p>
        @if (Model.AuthorUrl is not null)
        {
            <p>
                Website: <a href="@Model.AuthorUrl" rel="nofollow noopener noreferrer" target="_blank">@Model.AuthorUrl</a>
            </p>
        }
    </section>

    <footer class="post-footer">
    </footer>

</article>
