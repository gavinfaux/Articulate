@model PostModel

<!--- SHARING SECTION --->
<div class="post-share">
    <i class="share-button fa-solid fa-share fa-2x"></i>
    <a href="https://www.facebook.com/sharer.php?u=@Model.Url(mode: UrlMode.Absolute)" onclick="window.open(this.href, 'facebook-share','width=580,height=296');return false;"
       aria-label="Share on Facebook (opens in new window)"
       rel="noopener noreferrer" title="Share on Facebook (opens in new window)">
        <div class="share-button"><i class="fa-brands fa-facebook-f fa-2x" aria-hidden="true"></i></div>
    </a>
    <a href="https://x.com/share?text=@Model.Name&amp;url=@Model.Url(mode: UrlMode.Absolute)" onclick="window.open(this.href, 'x-share', 'width=550,height=235');return false;"
       aria-label="Share on X (opens in new window)"
       rel="noopener noreferrer" title="Share on X (opens in new window)">
        <div class="share-button"><i class="fa-brands fa-x-twitter fa-2x" aria-hidden="true"></i></div>
    </a>
</div>
