@addTagHelper *, Smidge
@inject Smidge.SmidgeHelper SmidgeHelper
@model global::Articulate.Models.MarkdownEditorInitModel

@{
    Layout = null;
    SmidgeHelper.RequiresCss("~/App_Plugins/Articulate/Assets/md-editor.css");
}

<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Articulate - Create New Post</title>
    <link rel="preconnect" href="https://code.getmdl.io">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preconnect" href="https://cdn.jsdelivr.net">
    <link rel="stylesheet" href="https://code.getmdl.io/1.0.0/material.pink-blue.min.css" fetchpriority="high">
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tiny-markdown-editor@0.2.0/dist/tiny-mde.min.css" integrity="sha256-MZ1zddO2Et4HONRzfJKJ1vC/Ecj9JIa3MI2GYCX2l5Y=" crossorigin="anonymous">
    <link rel="stylesheet" href="~/App_Plugins/Articulate/assets/md-editor.css" fetchpriority="high">

    <style>
        [x-cloak] {
            display: none !important;
        }
    </style>
</head>
<body x-data="markdownEditor" x-init="init" x-cloak
      data-articulate-node-id="@Model.ArticulateNodeId"
      data-auth-status-url="@Model.AuthStatusUrl"
      data-auth-signin-url="@Model.AuthSignInUrl"
      data-auth-csrf-url="@Model.AuthCsrfTokenUrl"
      data-auth-signout-url="@Model.AuthSignOutUrl"
      data-post-url="@Model.PostUrl">

    <div class="mdl-layout mdl-js-layout mdl-layout--fixed-header">
        <header class="mdl-layout__header">
            <div class="mdl-layout__header-row">
                <span class="mdl-layout-title" x-text="caption"></span>
                <div class="mdl-layout-spacer"></div>
                <div x-show="isLoading" class="mdl-spinner mdl-js-spinner is-active"></div>
            </div>
        </header>

        <main class="mdl-layout__content">
            <div class="page-content">

                <!-- Login View -->
                <template x-if="isLoginStep">
                    <div x-ref="loginView" class="mdl-card mdl-shadow--2dp fill-height">
                        <div class="mdl-card__supporting-text">
                            <form @@submit.prevent="handleLogin" novalidate>
                                <div class="mdl-textfield mdl-js-textfield" :class="loginErrorClass">
                                    <input class="mdl-textfield__input" type="text" id="email" :value="loginEmail" @@input="updateLoginEmail" autocomplete="username" required>
                                    <label class="mdl-textfield__label" for="email">Username...</label>
                                </div>

                                <div class="mdl-textfield mdl-js-textfield" :class="loginErrorClass">
                                    <input class="mdl-textfield__input" type="password" id="password" :value="loginPassword" @@input="updateLoginPassword" autocomplete="current-password" required>
                                    <label class="mdl-textfield__label" for="password">Password...</label>
                                    <span class="mdl-textfield__error" x-show="showLoginError" x-text="loginErrorMessage"></span>
                                </div>

                                <div class="btn-raised-right">
                                    <button type="submit" class="mdl-button mdl-js-button mdl-button--raised mdl-js-ripple-effect mdl-button--accent" :disabled="submitting">
                                        <span x-text="loginButtonText"></span>
                                    </button>
                                </div>

                                <template x-if="twoFactorUrl">
                                    <p style="margin-top: 16px;">Please <a :href="twoFactorUrl">click here</a> to complete your login.</p>
                                </template>
                            </form>
                        </div>
                    </div>
                </template>

                <!-- Editor View -->
                <template x-if="isEditorStep">
                    <div x-ref="editorView" class="mdl-card mdl-shadow--2dp fill-height">
                        <div class="mdl-card__supporting-text">
                            <div class="mdl-textfield mdl-js-textfield fixed" :class="titleErrorClass">
                                <input class="mdl-textfield__input" type="text" id="title" :value="postTitle" @@input="updatePostTitle" required>
                                <label class="mdl-textfield__label" for="title">Title...</label>
                            </div>
                            <div class="mdl-textfield mdl-js-textfield md-input">
                                <textarea x-ref="editor" id="editor" class="mdl-textfield__input"></textarea>
                                <label class="mdl-textfield__label" for="editor">## Start writing your post here...</label>
                            </div>
                        </div>
                    </div>
                </template>

                <!-- Optional View -->
                <template x-if="isOptionalStep">
                    <div x-ref="optionalView" class="mdl-card mdl-shadow--2dp fill-height">
                        <div class="mdl-card__supporting-text">
                            <div class="mdl-textfield mdl-js-textfield">
                                <input class="mdl-textfield__input" type="text" id="tags" :value="postTags" @@input="updatePostField">
                                <label class="mdl-textfield__label" for="tags">Tags (comma separated)</label>
                            </div>
                            <div class="mdl-textfield mdl-js-textfield">
                                <input class="mdl-textfield__input" type="text" id="categories" :value="postCategories" @@input="updatePostField">
                                <label class="mdl-textfield__label" for="categories">Categories (comma separated)</label>
                            </div>
                            <div class="mdl-textfield mdl-js-textfield">
                                <textarea class="mdl-textfield__input" id="excerpt" :value="postExcerpt" @@input="updatePostField" rows="3"></textarea>
                                <label class="mdl-textfield__label" for="excerpt">Excerpt</label>
                            </div>
                            <div class="mdl-textfield mdl-js-textfield">
                                <input class="mdl-textfield__input" type="text" id="slug" :value="postSlug" @@input="updatePostField">
                                <label class="mdl-textfield__label" for="slug">Slug</label>
                            </div>
                        </div>
                    </div>
                </template>

                <!-- Success View -->
                <template x-if="isSuccessStep">
                    <div x-ref="successView" class="mdl-card mdl-shadow--2dp">
                        <div class="mdl-card__supporting-text">
                            <h3>Success!</h3>
                            <p>Your post has been published.</p>
                        </div>
                        <div class="mdl-card__actions mdl-card--border">
                            <a :href="successUrl" class="mdl-button mdl-button--colored mdl-js-button mdl-js-ripple-effect">
                                Click here to view your post
                            </a>
                        </div>
                        <div class="mdl-card__menu">
                            <a href="#" @@click.prevent="resetForNewPost" class="mdl-button mdl-button--colored mdl-js-button mdl-js-ripple-effect">
                                Create another post
                            </a>
                        </div>
                    </div>
                </template>

            </div>
        </main>
    </div>

    <!-- Hidden file inputs -->
    <div class="hidden-insert-file">
        <input x-ref="imageUpload" type="file" accept="image/jpeg,image/png,image/gif" @@change="handleFileSelect">
        <input x-ref="cameraUpload" type="file" accept="image/jpeg,image/png,image/gif" capture="user" @@change="handleFileSelect">
    </div>

    <!-- Floating Action Buttons -->
    <div class="btn-fab-left">
        <button x-show="isEditorStep" @@click="triggerImageUpload" class="mdl-button mdl-js-button mdl-button--fab mdl-js-ripple-effect mdl-button--colored material-icons" title="Upload Image">photo</button>
        <button x-show="isEditorStep" @@click="triggerCamera" class="mdl-button mdl-js-button mdl-button--fab mdl-js-ripple-effect mdl-button--colored material-icons" title="Use Camera">photo_camera</button>
    </div>

    <div class="btn-fab-right">
        <button x-show="isOptionalStep" @@click="goToEditorStep" style="transform: rotate(180deg);" class="mdl-button mdl-js-button mdl-button--fab mdl-js-ripple-effect mdl-button--accent material-icons" title="Back">forward</button>
        <button x-show="canShowNextButton" @@click="goToOptionalStep" class="mdl-button mdl-js-button mdl-button--fab mdl-js-ripple-effect mdl-button--accent material-icons" title="Next">forward</button>
        <button x-show="isOptionalStep" @@click="handlePublish" class="mdl-button mdl-js-button mdl-button--raised mdl-js-ripple-effect mdl-button--accent" :disabled="submitting">Post It!</button>
    </div>

    <script defer src="https://code.getmdl.io/1.0.0/material.min.js" crossorigin="anonymous"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/tiny-markdown-editor@0.2.0/dist/tiny-mde.min.js" integrity="sha256-3RX+4eonZtpTV5BuscEas9t44jhaxeOaQ9T/tP8SeC0=" crossorigin="anonymous"></script>
    <script defer src="~/App_Plugins/Articulate/assets/md-editor.js"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/@@alpinejs/csp@3.14.9/dist/cdn.min.js" integrity="sha256-ggvJUDh0AkBX2iRNwwwhMBVIMp65oA55N+kcTTkIsnM=" crossorigin="anonymous"></script>

</body>
</html>
