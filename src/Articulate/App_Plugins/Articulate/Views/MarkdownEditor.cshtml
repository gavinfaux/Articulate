@addTagHelper *, Smidge
@inject Smidge.SmidgeHelper SmidgeHelper
@using Microsoft.AspNetCore.Antiforgery
@inject IAntiforgery Antiforgery
@model global::Articulate.Models.MarkdownEditorInitModel

@{
    Layout = null;

    SmidgeHelper
        .RequiresJs("~/App_Plugins/Articulate/Assets/md-editor.js")
        .RequiresCss("~/App_Plugins/Articulate/Assets/md-editor.css");
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Articulate - Create New Post</title>

    <link rel="stylesheet" href="https://code.getmdl.io/1.3.0/material.pink-blue.min.css" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/icon?family=Material+Icons" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tiny-markdown-editor@0.2.0/dist/tiny-mde.min.css" integrity="sha256-MZ1zddO2Et4HONRzfJKJ1vC/Ecj9JIa3MI2GYCX2l5Y=" crossorigin="anonymous">

    @await SmidgeHelper.CssHereAsync()

    <style>
        [x-cloak] {
            display: none !important;
        }
    </style>

    <script defer src="https://code.getmdl.io/1.3.0/material.min.js"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/tiny-markdown-editor@0.2.0/dist/tiny-mde.min.js" integrity="sha256-3RX+4eonZtpTV5BuscEas9t44jhaxeOaQ9T/tP8SeC0=" crossorigin="anonymous"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/@@alpinejs/csp@3.x.x/dist/cdn.min.js"></script>

    @await SmidgeHelper.JsHereAsync()
</head>
<body x-data="app" x-init="init" x-cloak 
      data-articulate-node-id="@Model.ArticulateNodeId" 
      data-auth-status-url="@Model.AuthStatusUrl" 
      data-auth-signin-url="@Model.AuthSignInUrl" 
      data-auth-csrf-url="@Model.AuthCsrfTokenUrl" 
      data-auth-signout-url="@Model.AuthSignOutUrl" 
      data-post-url="@Model.PostUrl">

    <div class="mdl-layout mdl-js-layout mdl-layout--fixed-header">
        <header class="mdl-layout__header">
            <div class="mdl-layout__header-row">
                <span class="mdl-layout-title" x-text="caption"></span>
                <div class="mdl-layout-spacer"></div>
                <div x-show="isLoading" class="mdl-spinner mdl-js-spinner is-active"></div>
            </div>
        </header>

        <main class="mdl-layout__content">
            <div class="page-content">
                <div class="container">

                    <!-- Login View -->
                    <div x-show="isLoginStep" class="mdl-card mdl-shadow--2dp fill-height">
                        <div class="mdl-card__supporting-text">
                            <form @@submit.prevent="handleLogin" novalidate>
                                <div class="mdl-textfield mdl-js-textfield mdl-textfield--floating-label">
                                    <input class="mdl-textfield__input" type="email" id="email" x-model="login.emailAddress" required :aria-invalid="isEmailInvalid" />
                                    <label class="mdl-textfield__label" for="email">Email Address</label>
                                </div>
                                <div class="mdl-textfield mdl-js-textfield mdl-textfield--floating-label">
                                    <input class="mdl-textfield__input" type="password" id="password" x-model="login.password" required :aria-invalid="isPasswordInvalid" />
                                    <label class="mdl-textfield__label" for="password">Password</label>
                                </div>
                                <template x-if="twoFactorUrl">
                                    <p>Please <a :href="twoFactorUrl">click here</a> to complete your login.</p>
                                </template>
                                <div class="btn-raised-right">
                                    <button type="submit" class="mdl-button mdl-js-button mdl-button--raised mdl-js-ripple-effect mdl-button--accent" :disabled="submitting">Login</button>
                                </div>
                            </form>
                        </div>
                    </div>

                    <!-- Editor View -->
                    <div x-show="isEditorStep" class="mdl-card mdl-shadow--2dp fill-height">
                        <div class="mdl-card__supporting-text">
                            <div class="mdl-textfield mdl-js-textfield mdl-textfield--floating-label fixed">
                                <input class="mdl-textfield__input" type="text" id="title" x-model="post.title" required />
                                <label class="mdl-textfield__label" for="title">Title...</label>
                            </div>
                            <div class="editor-container">
                                <textarea x-ref="editor" id="editor"></textarea>
                            </div>
                        </div>
                    </div>

                    <!-- Optional View -->
                    <div x-show="isOptionalStep" class="mdl-card mdl-shadow--2dp fill-height">
                        <div class="mdl-card__supporting-text">
                            <div class="mdl-textfield mdl-js-textfield mdl-textfield--floating-label">
                                <input class="mdl-textfield__input" type="text" id="tags" x-model="post.tags" />
                                <label class="mdl-textfield__label" for="tags">Tags (comma separated)</label>
                            </div>
                            <div class="mdl-textfield mdl-js-textfield mdl-textfield--floating-label">
                                <input class="mdl-textfield__input" type="text" id="categories" x-model="post.categories" />
                                <label class="mdl-textfield__label" for="categories">Categories (comma separated)</label>
                            </div>
                            <div class="mdl-textfield mdl-js-textfield mdl-textfield--floating-label">
                                <textarea class="mdl-textfield__input" id="excerpt" x-model="post.excerpt" rows="3"></textarea>
                                <label class="mdl-textfield__label" for="excerpt">Excerpt</label>
                            </div>
                            <div class="mdl-textfield mdl-js-textfield mdl-textfield--floating-label">
                                <input class="mdl-textfield__input" type="text" id="slug" x-model="post.slug" />
                                <label class="mdl-textfield__label" for="slug">Slug</label>
                            </div>
                        </div>
                    </div>

                    <!-- Success View -->
                    <div x-show="isSuccessStep" class="mdl-card mdl-shadow--2dp">
                        <div class="mdl-card__supporting-text">
                            <h3>Success!</h3>
                            <p>Your post has been published.</p>
                        </div>
                        <div class="mdl-card__actions mdl-card--border">
                            <a :href="successUrl" class="mdl-button mdl-button--colored mdl-js-button mdl-js-ripple-effect">
                                Click here to view your post
                            </a>
                        </div>
                         <div class="mdl-card__menu">
                            <a href="#" @@click.prevent="resetForNewPost" class="mdl-button mdl-button--colored mdl-js-button mdl-js-ripple-effect">
                                Create another post
                            </a>
                        </div>
                    </div>

                </div>
            </div>
        </main>
    </div>

    <!-- Hidden file inputs -->
    <div class="hidden-insert-file">
        <input x-ref="imageUpload" type="file" accept="image/jpeg,image/png,image/gif" @@change="handleFileSelect" />
        <input x-ref="cameraUpload" type="file" accept="image/jpeg,image/png,image/gif" capture="environment" @@change="handleFileSelect" />
    </div>

    <!-- Floating Action Buttons -->
    <div class="btn-fab-left">
        <button x-show="isEditorStep" @@click="triggerImageUpload" class="mdl-button mdl-js-button mdl-button--fab mdl-js-ripple-effect mdl-button--colored material-icons" title="Upload Image">photo</button>
        <button x-show="isEditorStep" @@click="triggerCamera" class="mdl-button mdl-js-button mdl-button--fab mdl-js-ripple-effect mdl-button--colored material-icons" title="Use Camera">photo_camera</button>
    </div>

    <div class="btn-fab-right">
        <button x-show="isOptionalStep" @@click="goToEditorStep" style="transform: rotate(180deg);" class="mdl-button mdl-js-button mdl-button--fab mdl-js-ripple-effect mdl-button--accent material-icons" title="Back">forward</button>
        <button x-show="canShowNextButton" @@click="goToOptionalStep" class="mdl-button mdl-js-button mdl-button--fab mdl-js-ripple-effect mdl-button--accent material-icons" title="Next">forward</button>
        <button x-show="isOptionalStep" @@click="handlePublish" class="mdl-button mdl-js-button mdl-button--raised mdl-js-ripple-effect mdl-button--accent" :disabled="submitting">Post It!</button>
    </div>

</body>
</html>
