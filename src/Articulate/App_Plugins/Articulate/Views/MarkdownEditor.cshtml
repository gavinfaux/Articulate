@{
    Layout = null;
}
<!doctype html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Articulate Mobile Editor</title>

    <!-- We will use the built assets from our Vite project -->
    <link rel="stylesheet" href="@Url.Content("~/App_Plugins/Articulate/assets/main.css")" />

    <style>
        [x-cloak] { display: none !important; }
    </style>
</head>
<body>
    <!--
        The entire UI is managed by Alpine.js.
        The `x-data="app"` attribute initializes our Alpine component, which is defined in the main.js file.
    -->
    <main class="container" x-data="app" x-init="init()" x-cloak>
        <header>
            <h1>Articulate Editor</h1>
            <progress x-show="isLoading"></progress>
        </header>

        <!-- Error Message -->
        <article x-show="errorMessage" style="background-color: var(--pico-form-element-invalid-background-color);">
            <p x-text="errorMessage"></p>
        </article>

        <!-- Login View (step 1) -->
        <article x-show="step === 1">
            <form @@submit.prevent="handleLogin">
                <label for="username">Username (Email)</label>
                <input x-model="formData.username" type="email" id="username" required />
                <label for="password">Password</label>
                <input x-model="formData.password" type="password" id="password" required />
                <button type="submit" :aria-busy="isLoading">Login</button>
            </form>
        </article>

        <!-- Editor View (step 2) -->
        <article x-show="step === 2">
            <label for="title">Title</label>
            <input x-model="formData.title" type="text" id="title" placeholder="Your post title..." required />
            <textarea x-ref="editor"></textarea>
            <footer>
                <button @@click="goToOptionalInfo()">Optional Info &rarr;</button>
            </footer>
        </article>

        <!-- Optional Info View (step 3) -->
        <article x-show="step === 3">
            <label for="author">Author</label>
            <input x-model="formData.author" type="text" id="author" placeholder="e.g. John Doe" />

            <label for="tags">Tags (comma separated)</label>
            <input x-model="formData.tags" type="text" id="tags" placeholder="e.g. csharp, umbraco, .net" />

            <label for="excerpt">Excerpt</label>
            <textarea x-model="formData.excerpt" id="excerpt" rows="3"></textarea>

            <label for="publishDate">Publish Date</label>
            <input x-model="formData.published" type="datetime-local" id="publishDate" />

            <footer>
                <button class="secondary" @@click="goToEditor()">&larr; Back to Editor</button>
                <button @@click="handlePublish()" :aria-busy="isLoading">Post It!</button>
            </footer>
        </article>

        <!-- Success View (step 4) -->
        <article x-show="step === 4">
            <h2>Success!</h2>
            <p>Your post has been published.</p>
            <!-- In a real scenario, the API would return the URL of the new post -->
            <a href="#" role="button">View Your Post</a>
        </article>
    </main>

    <!-- This script is the compiled output from our Vite/TypeScript project -->
    <script type="module" src="@Url.Content("~/App_Plugins/Articulate/assets/main.js")"></script>
</body>
</html>
