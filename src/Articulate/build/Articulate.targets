<Project>

  <PropertyGroup>
    <ArticulateContentFilesPath>$(MSBuildThisFileDirectory)..\App_Plugins\Articulate\**\*.*</ArticulateContentFilesPath>
  </PropertyGroup>

  <Target Name="CopyArticulateAssets" BeforeTargets="Build">
    <ItemGroup>
      <ArticulateContentFiles Include="$(ArticulateContentFilesPath)" />
    </ItemGroup>
    <Message Text="Copying Articulate files: $(ArticulateContentFilesPath) - #@(ArticulateContentFiles->Count()) files"
             Importance="high" />
    <Copy
      SourceFiles="@(ArticulateContentFiles)"
      DestinationFiles="@(ArticulateContentFiles->'$(MSBuildProjectDirectory)\App_Plugins\Articulate\%(RecursiveDir)%(Filename)%(Extension)')"
      SkipUnchangedFiles="true" />

  </Target>

  <Target Name="ClearArticulateAssets" BeforeTargets="Clean">
    <ItemGroup>
      <ArticulateDir Include="$(MSBuildProjectDirectory)\App_Plugins\Articulate\" />
    </ItemGroup>
    <Message Text="Clear old Articulate data" Importance="high" />
    <RemoveDir Directories="@(ArticulateDir)" />
  </Target>

  <Target Name="Articulate_ForceCopyXmlToOutput" AfterTargets="PrepareForRun">
    <ItemGroup>
      <_ArticulateDllSourceItem Include="@(ReferenceCopyLocalPaths)"
                                Condition="$([System.String]::new('%(Filename)').Equals('Articulate'))" />
    </ItemGroup>
    <PropertyGroup>
      <_ArticulateSourceXmlPath>$([System.IO.Path]::ChangeExtension('%(_ArticulateDllSourceItem.FullPath)', '.xml'))</_ArticulateSourceXmlPath>
      <_ArticulateDestXmlPath>$(OutDir)Articulate.xml</_ArticulateDestXmlPath>
    </PropertyGroup>
    <Message
      Text="[Articulate] Forcing copy of documentation file. Source: '$(_ArticulateSourceXmlPath)'. Destination: '$(_ArticulateDestXmlPath)'."
      Importance="high" />
    <Copy SourceFiles="$(_ArticulateSourceXmlPath)" DestinationFiles="$(_ArticulateDestXmlPath)"
          SkipUnchangedFiles="true" Condition="Exists('$(_ArticulateSourceXmlPath)')" />
  </Target>

</Project>
