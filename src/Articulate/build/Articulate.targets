<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <Target Name="CopyArticulateAssetsOnBuild" BeforeTargets="Build">
    <PropertyGroup>
      <ArticulateSourcePath>$(MSBuildThisFileDirectory)..\App_Plugins\Articulate\</ArticulateSourcePath>
      <ArticulateDestPath>$(MSBuildProjectDirectory)\App_Plugins\Articulate\</ArticulateDestPath>
    </PropertyGroup>

    <ItemGroup>
      <ArticulateSourceFiles Include="$(ArticulateSourcePath)\**\*" />
    </ItemGroup>

    <Message Text="[Articulate] Copying assets to $(ArticulateDestPath)" Importance="high" />
    <Copy
      SourceFiles="@(ArticulateSourceFiles)"
      DestinationFiles="@(ArticulateSourceFiles->'$(ArticulateDestPath)%(RecursiveDir)%(Filename)%(Extension)')"
      SkipUnchangedFiles="false"
    />
  </Target>

  <Target Name="ClearArticulateAssetsOnClean" BeforeTargets="Clean">
    <PropertyGroup>
      <ArticulateDestPath>$(MSBuildProjectDirectory)\App_Plugins\Articulate\</ArticulateDestPath>
    </PropertyGroup>
    <Message Text="[Articulate] Removing assets from $(ArticulateDestPath)" Importance="high" />
    <RemoveDir Directories="$(ArticulateDestPath)" />
  </Target>

</Project>
