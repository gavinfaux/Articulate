<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <Target Name="CopyCustomXmlDocumentation" AfterTargets="ResolveAssemblyReferences">
    <ItemGroup>
      <!--Find the assembly from this package, hardcoded for now as assembly name != PackageId-->
      <ResolvedAssemblies Include="@(ReferencePathWithRefAssemblies)" Condition="'%(ReferencePathWithRefAssemblies.NuGetPackageId)' == 'Articulate.Core' AND '%(ReferencePathWithRefAssemblies.Filename)' == 'Articulate'" />
    </ItemGroup>

    <!--If we found the assembly, copy its corresponding XML file-->
    <Copy
      SourceFiles="@(ResolvedAssemblies->'%(RootDir)%(Directory)%(Filename).xml')"
      DestinationFolder="$(OutDir)"
      SkipUnchangedFiles="true"
      Condition="Exists('%(ResolvedAssemblies.Identity)') AND Exists('%(ResolvedAssemblies.RootDir)%(ResolvedAssemblies.Directory)%(ResolvedAssemblies.Filename).xml')"
    />
  </Target>
</Project>
