@model global::Articulate.Models.PagerModel

@if (Model.HasNext || Model.HasPrevious)
{
    <nav class="pagination" role="navigation" aria-label="Pagination Navigation">
        @if (Model.HasPrevious)
        {
            <a class="newer-posts" href="@Model.PreviousUrl" title="View Previous Page">
                <i class="fa-solid fa-circle-chevron-left"></i> Newer
            </a>
        }
        <span class="page-number">Page @(Model.CurrentPageIndex + 1) of @Model.TotalPages</span>
        @if (Model.HasNext)
        {
            <a class="older-posts" href="@Model.NextUrl" title="View Next Page">
                Older <i class="fa-solid fa-circle-chevron-right"></i>
            </a>
        }
    </nav>
}
