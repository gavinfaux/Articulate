    <Target Name="PreResolveProjectStaticWebAssets" BeforeTargets="ResolveProjectStaticWebAssets">
        <Message Text="[PreResolveProjectStaticWebAssets] Content: @(Content)" Importance="high" />
        <ItemGroup>
            <StashedContent Include="@(Content)" />
            <Content Remove="@(Content)" />
        </ItemGroup>
    </Target>
    <Target Name="PostResolveProjectStaticWebAssets" AfterTargets="ResolveProjectStaticWebAssets">
        <ItemGroup>
            <Content Include="@(StashedContent)" />
        </ItemGroup>
    </Target>


  <Target Name="DiagnoseStaticAssets" BeforeTargets="GenerateNuspec">
    <Message Importance="high" Text="--- Diagnosing Static Web Assets for packing ---" />
    <Message Importance="high" Text="The following items were found in the '@(StaticWebAsset)' group:" />
    <Message Importance="high" Text="@(StaticWebAsset->'  - %(Identity) -> Mapped to: %(RelativePath)')" />
    <Message Importance="high" Text="--------------------------------------------------" />
  </Target>
</Project>
