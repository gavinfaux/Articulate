    -->
    <!-- End of default NPM client build example -->


  <!-- Start of dotnet pack build workaround -->

  <!-- So, with StaticWebAssets set to root folder '/', EnableDefaultContentItems set to true (or not defined) and vite outDir set to "../wwwroot/App_Plugins/Articulate/Backoffice Visual Studio Pack correctly packages *all* client assets (BackOffice, Themes, MarkdownEditor, etc.) and produces the required build/Articulate.props, build\Microsoft.AspNetCore.StaticWebAssets.props and build\Microsoft.AspNetCore.StaticWebAssetEndpoints.props files in the NuGet package allowing the target Umbraco website project to combine Articulate static assets with Umbraco static assets, and everything just works. However, dotnet pack is not packing *any* Articulate static assets or the Articulate.props file. So we have to take control and do it ourselves :-( -->
  <!-- Copied from https://github.com/umbraco/Umbraco.AuthorizedServices/blob/main/src/Umbraco.AuthorizedServices/Umbraco.AuthorizedServices.csproj -->
  <!-- Build client assets using NPM -->
  <Import Project="build\Microsoft.AspNetCore.ClientAssets.targets" />
  <PropertyGroup>
    <!-- Use this to (temporarily) disable building client assets, e.g. to start the project and generate updated API models -->
    <ShouldRunClientAssetsBuild>true</ShouldRunClientAssetsBuild>
    <!-- We should always run the build in Release though? -->
    <ShouldRunClientAssetsBuild Condition="'$(Configuration)' == 'Release'">true</ShouldRunClientAssetsBuild>
  </PropertyGroup>
  <!-- StaticWebAssetBasePath is App_Plugins/Articulate so clientassets will resolve to this, we output the BackOffice to clientassets/BackOffice via writing to Client\config.outputPath.js which vite.config references to set outDir, our versioningPlugin will then move umbraco-package.json from BackOffice up one level to clientassets/ so umbraco-package.json is found by Umbraco at App_Plugins/Articulate/umbraco-package.json -->
  <Target Name="ClientAssetsBuildOutputPath" BeforeTargets="ClientAssetsBuild">
    <WriteLinesToFile File="Client\config.outputPath.js" Lines="export const outputPath = '../$(IntermediateOutputPath.Replace('\', '/'))clientassets/BackOffice';" Overwrite="true" />
  </Target>

  <!-- So BackOffice is sorted, but we now have to handle any other static assets in our package and ensure they are also in the clientassets folder to be included in the NuGet package. -->
  <PropertyGroup>
    <ArticulateStaticAssetsSource>$(MSBuildProjectDirectory)/wwwroot/App_Plugins/Articulate</ArticulateStaticAssetsSource>
  </PropertyGroup>
  <Target Name="CopyStaticAssetsForPackage" AfterTargets="ClientAssetsBuild">
    <!-- Define the items to include. This finds all files in the Articulate App_Plugin folder... -->
    <ItemGroup>
      <StaticPackageAssets Include="$(ArticulateStaticAssetsSource)/**" />
      <!--
      Define the items to exclude.
      1. Exclude the BackOffice directory since Vite handles that.
      2. Exclude any .cshtml files.
      -->
      <StaticPackageAssets Remove="$(ArticulateStaticAssetsSource)/Backoffice/**" />
      <StaticPackageAssets Remove="$(ArticulateStaticAssetsSource)/**/*.cshtml" />
    </ItemGroup>
    <!-- Copy the filtered files to the client assets output path, maintaining the folder structure. -->
    <Copy SourceFiles="@(StaticPackageAssets)" DestinationFolder="$(IntermediateOutputPath)clientassets/%(RecursiveDir)" SkipUnchangedFiles="true" />
  </Target>

  <!-- Since EnableDefaultContentItems is now false, we need to define the content items to include, currently only the cshtml files so they can be compiled -->
  <ItemGroup>
    <Content Include="wwwroot\**\*.cshml" />
  </ItemGroup>

  <!-- End of dotnet pack build workaround -->

  <!-- We need to embed the themes folder also for the back office Copy Theme feature (RCL compiles views and packs static assets so no 'folder' to copy from) -->
  <ItemGroup>
    <EmbeddedResource Include="wwwroot\App_Plugins\Articulate\Themes\**">
      <LogicalName>Articulate.Themes/$([System.String]::Copy('%(RecursiveDir)').Replace('\', '/'))%(Filename)%(Extension)</LogicalName>
    </EmbeddedResource>
  </ItemGroup>

  <!-- Rest of original Articulate build -->
  <ItemGroup>
    <Compile Update="Controllers\Resources.Designer.cs">
      <AutoGen>True</AutoGen>
      <DesignTime>True</DesignTime>
      <DependentUpon>Resources.resx</DependentUpon>
    </Compile>
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Update="Controllers\Resources.resx">
      <Generator>ResXFileCodeGenerator</Generator>
      <LastGenOutput>Resources.Designer.cs</LastGenOutput>
    </EmbeddedResource>
  </ItemGroup>

  <ItemGroup>
    <None Remove="Packaging\package.zip" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Packaging\author.jpg" />
    <EmbeddedResource Include="Packaging\banner.jpg" />
    <EmbeddedResource Include="Packaging\logo.png" />
    <EmbeddedResource Include="Packaging\package.zip" />
    <EmbeddedResource Include="Packaging\post1.jpg" />
    <EmbeddedResource Include="Packaging\post2.jpg" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\..\LICENSE">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </None>
    <None Include="..\..\README.md">
      <Pack>true</Pack>
      <PackagePath>\</PackagePath>
    </None>
  </ItemGroup>

</Project>
