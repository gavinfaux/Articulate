{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "lib": ["ESNext", "DOM"],
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "types": ["@umbraco-cms/backoffice/extension-types", "@umbraco-cms/backoffice/external/lit"]
  },
  "include": ["src/**/*.ts"]
}
