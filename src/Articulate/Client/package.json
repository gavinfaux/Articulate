{
  "name": "articulate-backoffice",
  "private": true,
  "version": "6.0.0-g1f4f86bc24",
  "type": "module",
  "description": "Articulate BackOffice extension",
  "keywords": [],
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:release": "tsc && npm run set-version && vite build",
    "preview": "vite preview",
    "watch": "vite build --watch",
    "format": "prettier --write .",
    "lint": "eslint .",
    "check": "tsc --noEmit",
    "generate-client": "node ./scripts/generate-openapi.js https://localhost:44366/umbraco/swagger/articulate/swagger.json ./src/api --excludeTags 'Markdown Editor'",
    "set-version": "node ./scripts/update-version.js ./package.json"
  },
  "dependenciesComments": {
    "monaco-editor": "Articulate Markdown Editor property editor (not the mobile markdown editor), only required until Umbraco Core editor supports better markdown to HTML processing; see https://github.com/umbraco/Umbraco-CMS/issues/19500"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.80.1",
    "@umbraco-cms/backoffice": "^15.4.3",
    "chalk": "^5.4.1",
    "chokidar-cli": "^3.0.0",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^10.1.8",
    "fs-extra": "^11.2.0",
    "node-fetch": "^3.3.2",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.6.1",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.37.0",
    "vite": "^6.3.5"
  },
  "dependencies": {
    "monaco-editor": "^0.52.2"
  }
}
