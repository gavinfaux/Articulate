{
  "name": "articulate-backoffice",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Articulate BackOffice extension",
  "engines": {
    "node": ">=22",
    "npm": ">=11.5.1"
  },
  "keywords": [
    "blog",
    "umbraco",
    "backoffice",
    "lit",
    "web components"
  ],
  "author": "Articulate",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:release": "tsc && npm run set-version && vite build",
    "preview": "vite preview",
    "watch": "vite build --watch",
    "lint:errors": "npm run lint -- --quiet",
    "lint:fix": "npm run lint -- --fix",
    "lint": "eslint src",
    "check": "tsc --noEmit",
    "generate:api": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 openapi-ts -f openapi-ts.config.ts",
    "generate-client": "node ./scripts/generate-openapi.js http://localhost:44169/umbraco/swagger/articulate/swagger.json ./src/api --excludeTags 'Markdown Editor'",
    "set-version": "node ./scripts/update-version.js ./package.json"
  },
  "dependenciesComments": {
    "monaco-editor": "Articulate Markdown Editor property editor (not the mobile markdown editor), only required until Umbraco Core editor supports better markdown to HTML processing; see https://github.com/umbraco/Umbraco-CMS/issues/19500"
  },
  "peerDependencies": {
    "@umbraco-cms/backoffice": ">=15.4.3 <17.0.0"
  },
  "devDependencies": {
    "@eslint/compat": "^1.3.1",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.32.0",
    "@hey-api/openapi-ts": "~0.80.1",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "@umbraco-cms/backoffice": "~15.4.3",
    "chalk": "~5.4.1",
    "cross-env": "^10.0.0",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-lit": "^2.1.1",
    "eslint-plugin-lit-a11y": "^5.1.1",
    "eslint-plugin-local-rules": "^3.0.2",
    "eslint-plugin-wc": "^3.0.1",
    "fs-extra": "^11.3.0",
    "globals": "^16.3.0",
    "node-fetch": "~3.3.2",
    "typescript": "~5.8.2",
    "vite": "^7.0.6",
    "vite-tsconfig-paths": "~5.1.4"
  },
  "dependencies": {
    "monaco-editor": "^0.52.2"
  }
}
