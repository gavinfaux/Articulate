<Project Sdk="Microsoft.NET.Sdk.Razor">

  <PropertyGroup>
    <TargetFrameworks>net9.0;net10.0</TargetFrameworks>
    <Nullable>enable</Nullable>
    <PackageId>Articulate.StaticAssets</PackageId>
    <Title>Articulate Static Web Assets</Title>
    <ArticulateWebAssetsRoot>$([System.IO.Path]::GetFullPath('$(MSBuildProjectDirectory)/../Articulate.Web/wwwroot/App_Plugins/Articulate'))</ArticulateWebAssetsRoot>
    <ClientProjectDirectory>$([System.IO.Path]::GetFullPath('$(MSBuildProjectDirectory)/../Articulate.Api.Management/Client'))</ClientProjectDirectory>
  </PropertyGroup>

  <ItemGroup>
    <SupportedPlatform Include="browser" />
    <Folder Include="wwwroot/App_Plugins/Articulate/" />
  </ItemGroup>

  <ItemGroup Condition="Exists('$(ArticulateWebAssetsRoot)')">
    <!-- Mirror all Markdown editor assets except Razor views -->
    <ArticulateWebAsset Include="$(ArticulateWebAssetsRoot)/MarkdownEditor/**/*.*"
                        Exclude="$(ArticulateWebAssetsRoot)/MarkdownEditor/**/*.cshtml"
                        Condition="Exists('$(ArticulateWebAssetsRoot)/MarkdownEditor')">
      <RelativeCopyPath>$([MSBuild]::MakeRelative('$(ArticulateWebAssetsRoot)', '%(FullPath)'))</RelativeCopyPath>
    </ArticulateWebAsset>
    <!-- Mirror entire theme folders (excluding Razor views) -->
    <ArticulateWebAsset Include="$(ArticulateWebAssetsRoot)/Themes/**/*.*"
                        Exclude="$(ArticulateWebAssetsRoot)/Themes/**/*.cshtml"
                        Condition="Exists('$(ArticulateWebAssetsRoot)/Themes')">
      <RelativeCopyPath>$([MSBuild]::MakeRelative('$(ArticulateWebAssetsRoot)', '%(FullPath)'))</RelativeCopyPath>
    </ArticulateWebAsset>
  </ItemGroup>
  <ItemGroup>
    <!-- Only reference Articulate.Core for Razor model types; avoid coupling to Articulate.Web to prevent cyclic NuGet deps -->
    <ProjectReference Include="..\Articulate\Articulate.csproj" />
    <!-- Keep API management as a private, non-packaged build-time reference (for local asset workflows) -->
    <ProjectReference Include="..\Articulate.Api.Management\Articulate.Api.Management.csproj"
                      ReferenceOutputAssembly="false"
                      PrivateAssets="All" />
  </ItemGroup>
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <Target Name="SyncArticulateWebAssets"
          Condition="Exists('$(ArticulateWebAssetsRoot)')"
          BeforeTargets="ResolveStaticWebAssetsInputs"
          Inputs="@(ArticulateWebAsset)"
          Outputs="@(ArticulateWebAsset -> '$(MSBuildProjectDirectory)/wwwroot/App_Plugins/Articulate/%(RelativeCopyPath)')">
    <Message Text="Synchronizing Articulate.Web static assets into Articulate.StaticAssets" Importance="Low" />
    <PropertyGroup>
      <_TargetRoot>$(MSBuildProjectDirectory)/wwwroot/App_Plugins/Articulate</_TargetRoot>
    </PropertyGroup>
    <RemoveDir Directories="$(_TargetRoot)/Themes" Condition="Exists('$(_TargetRoot)/Themes')" />
    <RemoveDir Directories="$(_TargetRoot)/MarkdownEditor" Condition="Exists('$(_TargetRoot)/MarkdownEditor')" />
    <Copy SourceFiles="@(ArticulateWebAsset)"
          DestinationFiles="@(ArticulateWebAsset -> '$(MSBuildProjectDirectory)/wwwroot/App_Plugins/Articulate/%(RelativeCopyPath)')"
          SkipUnchangedFiles="true" />
  </Target>
</Project>
