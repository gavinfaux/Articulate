@model PostModel
@{
    var tags = Model.Tags.ToArray();
    var categories = Model.Categories.ToArray();
}

@if (tags.Any() || categories.Any())
{
    <div class="meta-pills" aria-label="Post topics">
        @foreach (var category in categories)
        {
            <a class="meta-pill meta-pill--category" href="@Model.ArticulateCategoryUrl(category)">
                <i class="fa-solid fa-folder-tree" aria-hidden="true"></i>
                <span>@category</span>
            </a>
        }
        @foreach (var tag in tags)
        {
            <a class="meta-pill" href="@Model.ArticulateTagUrl(tag)">
                <i class="fa-solid fa-hashtag" aria-hidden="true"></i>
                <span>@tag</span>
            </a>
        }
    </div>
}
