@model AuthorModel
@{
    Layout = "_Layout.cshtml";
    ViewBag.CssBodyClass = "page-author";
}

@section Head
{
    @Model.AuthorRssFeed()
}

<section class="page-hero">
    <div>
        <p class="page-hero__eyebrow">Author archive</p>
        <h1 class="page-hero__title">@Model.Name</h1>
        @if (!Model.Bio.IsNullOrWhiteSpace())
        {
            <p class="page-hero__summary">@Model.Bio</p>
        }
        <div class="post-article__details">
            <a href="@Model.ArticulateAuthorRssUrl()" aria-label="Author RSS feed">
                <i class="fa-solid fa-rss" aria-hidden="true"></i>
                <span>RSS</span>
            </a>
            @if (!Model.AuthorUrl.IsNullOrWhiteSpace())
            {
                <a href="@Model.AuthorUrl" rel="nofollow noopener noreferrer" target="_blank"><i class="fa-solid fa-arrow-up-right-from-square" aria-hidden="true"></i> Website</a>
            }
            <span>@Model.PostCount post@(Model.PostCount == 1 ? string.Empty : "s")</span>
        </div>
    </div>

    @if (!Model.CroppedWideUrl.IsNullOrWhiteSpace())
    {
        <img class="page-hero__portrait" src="@Model.CroppedWideUrl" alt="@Model.Name" width="640" height="400" fetchpriority="high">
    }
</section>

@if (!Model.Posts.Any())
{
    <section class="empty-state">
        <h2>No posts yet</h2>
        <p>This author does not have any published posts.</p>
    </section>
}
else
{
    <section class="post-grid-wrap">
        <div class="post-grid-wrap__header">
            <p class="page-hero__eyebrow">Archive</p>
            <h2 class="post-grid-wrap__title">Posts by @Model.Name</h2>
        </div>

        <section class="post-grid" aria-label="Posts by @Model.Name">
            @foreach (var post in Model.Posts)
            {
                @await Html.PartialAsync("PostCard", post)
            }
        </section>
    </section>

    @await Html.PartialAsync("Pager", Model.Pages)
}
