@model PostModel
@{
    Layout = "_Layout.cshtml";
    ViewBag.CssBodyClass = "page-post";
    var absUrl = Model.Url(mode: UrlMode.Absolute);
}

@section Head
{
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/prismjs@1.30.0/themes/prism.min.css" integrity="sha256-ko4j5rn874LF8dHwW29/xabhh8YBleWfvxb8nQce4Fc=" crossorigin="anonymous" media="all">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.38/dist/katex.min.css" integrity="sha256-RY5cj+WCt7sIKd7ocDoL1HSUDQ7IMt+1RVhHRVS2MJg=" crossorigin="anonymous" media="all">
}

<article class="post-article" itemscope itemtype="http://schema.org/BlogPosting">
    <header class="post-article__hero">
        <div class="post-article__meta">
            <p class="page-hero__eyebrow">Article</p>
            <h1 class="post-article__title" itemprop="headline">@Model.Name</h1>
            <div class="post-article__details">
                <time datetime="@Model.PublishedDate.ToString("yyyy-MM-dd")" itemprop="datePublished">
                    @Model.PublishedDate.ToString("dddd, MMMM dd, yyyy")
                </time>
                @if (!Model.Author.Name.IsNullOrWhiteSpace())
                {
                    <span>By @Model.Author.Name</span>
                }
            </div>
            @await Html.PartialAsync("PostTags", Model)
        </div>

        @if (!Model.CroppedPostImageUrl.IsNullOrWhiteSpace())
        {
            <img class="post-article__image" src="@Model.CroppedPostImageUrl" alt="@Model.Name" fetchpriority="high" width="960" height="540">
        }
    </header>

    <div class="post-article__body prose">
        @Model.Body
    </div>

    <section class="post-share" aria-label="Share this post">
        <div class="post-share__title">Share</div>
        <div class="post-share__actions">
            <button type="button" class="icon-button" data-share-button data-title="@Model.Name" data-url="@absUrl" aria-label="Share this post">
                <i class="fa-solid fa-share-nodes" aria-hidden="true"></i>
            </button>
            <a class="icon-button" href="https://x.com/share?text=@Uri.EscapeDataString(Model.Name)&url=@Uri.EscapeDataString(absUrl)" target="_blank" rel="noopener noreferrer" aria-label="Share on X">
                <i class="fa-brands fa-x-twitter" aria-hidden="true"></i>
            </a>
            <a class="icon-button" href="https://www.facebook.com/sharer/sharer.php?u=@Uri.EscapeDataString(absUrl)" target="_blank" rel="noopener noreferrer" aria-label="Share on Facebook">
                <i class="fa-brands fa-facebook-f" aria-hidden="true"></i>
            </a>
        </div>
    </section>

    @if (!Model.Author.Name.IsNullOrWhiteSpace())
    {
        <aside class="author-panel">
            @if (Model.Author.Image is not null)
            {
                <img class="author-panel__image" src="@Model.Author.Image.GetCropUrl(cropAlias: "wide", preferFocalPoint: true, useCropDimensions: true)" alt="@Model.Author.Name" width="240" height="160" loading="lazy">
            }
            <div>
                <p class="page-hero__eyebrow">Author</p>
                <h2>@Model.Author.Name</h2>
                @if (!Model.Author.Bio.IsNullOrWhiteSpace())
                {
                    <p>@Model.Author.Bio</p>
                }
                @if (!Model.Author.BlogUrl.IsNullOrWhiteSpace())
                {
                    <p><a href="@Model.Author.BlogUrl">View author archive</a></p>
                }
            </div>
        </aside>
    }

    @{
        var prevPost = Model.Previous();
        var nextPost = Model.Next();
    }
    @if (prevPost is not null || nextPost is not null)
    {
        <nav class="post-nav" aria-label="Post navigation">
            @if (prevPost is not null)
            {
                <a class="post-nav__link post-nav__link--prev" href="@prevPost.Url()" rel="prev">
                    <span class="post-nav__label"><i class="fa-solid fa-arrow-left" aria-hidden="true"></i> Older</span>
                    <span class="post-nav__title">@prevPost.Name</span>
                </a>
            }
            @if (nextPost is not null)
            {
                <a class="post-nav__link post-nav__link--next" href="@nextPost.Url()" rel="next">
                    <span class="post-nav__label">Newer <i class="fa-solid fa-arrow-right" aria-hidden="true"></i></span>
                    <span class="post-nav__title">@nextPost.Name</span>
                </a>
            }
        </nav>
    }

    @if (Model.EnableComments)
    {
        <section class="comments-panel">
            @await Html.PartialAsync("CommentsDisqus", Model)
        </section>
    }
</article>

@section Scripts
{
    <script src="https://cdn.jsdelivr.net/npm/prismjs@1.30.0/components/prism-core.min.js" integrity="sha256-bKrTFt2ZHyT4AE4LnBnAVctYKf9l6XP77kBvltgbjn4=" crossorigin="anonymous" defer></script>
    <script src="https://cdn.jsdelivr.net/npm/prismjs@1.30.0/plugins/autoloader/prism-autoloader.min.js" integrity="sha256-AjM0J5XIbiB590BrznLEgZGLnOQWrt62s3BEq65Q/I0=" crossorigin="anonymous" data-autoloader-path="https://cdn.jsdelivr.net/npm/prismjs@1.30.0/components/" defer></script>
    <script src="https://cdn.jsdelivr.net/npm/katex@0.16.38/dist/katex.min.js" integrity="sha256-G2hiT4+WhwSWAR3lRvrTOAWxEuHhwPf6Z17ea6pHE2w=" crossorigin="anonymous" defer></script>
    <script src="https://cdn.jsdelivr.net/npm/katex@0.16.38/dist/contrib/auto-render.min.js" integrity="sha256-5TctGZvNrotN5x0PfOunKkuhJ3SifGCm8fd9A7MijuQ=" crossorigin="anonymous" defer></script>
    <script src="https://cdn.jsdelivr.net/npm/mermaid@11.13.0/dist/mermaid.min.js" integrity="sha256-PiACvzM5B/rnwdaGC7x49dpBe8cLZPPSJoWBuguouWo=" crossorigin="anonymous" defer></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            if (window.renderMathInElement) {
                renderMathInElement(document.body, {
                    delimiters: [
                        { left: "$$", right: "$$", display: true },
                        { left: "$", right: "$", display: false },
                        { left: "\\(", right: "\\)", display: false },
                        { left: "\\[", right: "\\]", display: true }
                    ],
                    throwOnError: false
                });
            }

            if (window.mermaid) {
                mermaid.initialize({ startOnLoad: true });
            }
        });
    </script>
}
