{
  "$schema": "appsettings-schema.json",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    }
  },
  "Umbraco": {
    "CMS": {
      "Content": {
        "AllowEditInvariantFromNonDefault": true,
        "ContentVersionCleanupPolicy": {
          "EnableCleanup": true
        }
      },
      "DeliveryApi": {
        "Enabled": true
      },
      "Global": {
        "Id": "1bf3cfb0-a911-463d-8ae7-6125058b810a",
        "SanitizeTinyMce": true,
        "InstallMissingDatabase": true,
        "DisableElectionForSingleServer": true
      },
      "Hosting": {
        "Debug": false
      },
      "Runtime": {
        "MaxRequestLength": 50000
      },
      "Security": {
        "AllowConcurrentLogins": false
      },
      "Unattended": {
        "InstallUnattended": true,
        "UnattendedUserName": "admin",
        "UnattendedUserEmail": "admin@example.com",
        "UnattendedUserPassword": "ChangeMe123!"
      },
      "WebRouting": {
        "UmbracoApplicationUrl": "https://localhost:44366/"
      }
    }
  },
  "Articulate": {
    "AutoGenerateExcerpt": true,
    "AutoPublishOnStartup": true,
    "AllowedImageExtensions": [
      "jpg",
      "jpeg",
      "png",
      "gif",
      "webp"
    ],
    "MaxImageLength": 10000,
    "ManagementApi": {
      "OpenIddict": {
        "Client": {
          "Enabled": true,
          "ClientId": "umbraco-articulate",
          "DisplayName": "Articulate Markdown Editor",
          "RedirectUris": [
            "https://localhost:44366/a-new/"
          ],
          "PostLogoutRedirectUris": [
            "https://localhost:44366/umbraco/management/api/v1/security/back-office/signout?post_logout_redirect_uri=https%3A%2F%2Flocalhost%3A44366%2F",
            "https://localhost:44366/"
          ]
        }
      }
    }
  },
  "ConnectionStrings": {
    "umbracoDbDSN": "Data Source=|DataDirectory|/Umbraco.sqlite.db;Cache=Shared;Foreign Keys=True;Pooling=True",
    "umbracoDbDSN_ProviderName": "Microsoft.Data.Sqlite"
  }
}
