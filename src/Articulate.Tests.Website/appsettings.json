{
  "$schema": "appsettings-schema.json",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    }
  },
  "Umbraco": {
    "CMS": {
      "Hosting": {
        "Debug": false
      },
      "Global": {
        "Id": "1bf3cfb0-a911-463d-8ae7-6125058b810a",
        "UseHttps": true,
        "SanitizeTinyMce": true
      },
      "Content": {
        "AllowEditInvariantFromNonDefault": true,
        "ContentVersionCleanupPolicy": {
          "EnableCleanup": true
        }
      },
      "DeliveryApi": {
        "Enabled": true
      },
      "Unattended": {
        "UpgradeUnattended": true
      },
      "Security": {
        "BackOfficeHost": "https://localhost:5001",
        "AllowConcurrentLogins": false
      },
      "WebRouting": {
        "UmbracoApplicationUrl": "https://localhost:5001/"
      }
    }
  },
  "Articulate": {
    "ManagementApi": {
      "OpenIddict": {
        "Client": {
          "Enabled": true,
          "ClientId": "umbraco-articulate",
          "DisplayName": "Articulate Markdown Editor",
          "RedirectUris": [
            "https://localhost:5001/a-new/"
          ],
          "PostLogoutRedirectUris": [
            "https://localhost:5001/"
          ]
        }
      }
    }
  }
}
