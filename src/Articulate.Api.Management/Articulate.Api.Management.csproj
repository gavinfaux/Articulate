<Project Sdk="Microsoft.NET.Sdk.Razor">
  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <CompressionEnabled>false</CompressionEnabled>
    <StaticWebAssetBasePath>/</StaticWebAssetBasePath>
  </PropertyGroup>

  <PropertyGroup>
    <PackageId>Articulate.Management.Api</PackageId>
    <Title>Articulate BackOffice Api</Title>
  </PropertyGroup>

  <!--NoWarn for missing XML comments on public API-->
  <PropertyGroup>
    <NoWarn>$(NoWarn);1591</NoWarn>
  </PropertyGroup>

  <!--
    Nuget - Dotnet SourceLink & Symbol Package
    https://github.com/dotnet/sourcelink#using-source-link-in-net-projects
    https://devblogs.microsoft.com/dotnet/producing-packages-with-source-link/

    Newer recommended way from Claire Novotny - Nuget PM
    Use package Dotnet.ReproducibleBuilds
    This sets the same properties as above URLs, and a few additional build properties
    ie less work - just include this package & be done...
    https://github.com/dotnet/reproducible-builds
    -->
  <ItemGroup>
    <PackageReference Include="DotNet.ReproducibleBuilds" Version="1.2.25">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers, buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <!--Umbraco CMS version range + NuGet audit mode-->
  <PropertyGroup>
    <UmbracoCmsPackageVersion>[15.2.3, 16.999.999)</UmbracoCmsPackageVersion>
    <NuGetAuditMode>direct</NuGetAuditMode>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Umbraco.Cms.Web.Website" Version="$(UmbracoCmsPackageVersion)" />
    <PackageReference Include="Umbraco.Cms.Web.Common" Version="$(UmbracoCmsPackageVersion)" />
    <PackageReference Include="Umbraco.Cms.Api.Common" Version="$(UmbracoCmsPackageVersion)" />
    <PackageReference Include="Umbraco.Cms.Api.Management" Version="$(UmbracoCmsPackageVersion)" />

    <PackageReference Include="Microsoft.CodeAnalysis" Version="4.14.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Articulate\Articulate.csproj" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Articulate.Web" />
  </ItemGroup>

  <!--Additional implicit using directives-->
  <ItemGroup>
    <Using Include="Umbraco.Cms.Core.DependencyInjection" />
    <Using Include="Umbraco.Extensions" />
    <Using Include="Articulate" />
  </ItemGroup>

  <ItemGroup>
    <ClientAssetsInput Include="Client\**" Exclude="$(DefaultItemExcludes)" />
    <!-- Dont include the client folder as part of packaging nuget build -->
    <Content Remove="Client\**" />
    <!-- However make the Umbraco-package.json included for dotnet pack or nuget package and visible to the solution -->
    <None Include="Client\public\umbraco-package.json" Pack="false" />
  </ItemGroup>

  <!-- Conditionals for CI build-->
  <PropertyGroup>
    <IsCiBuild Condition="'$(IsCiBuild)' == ''">false</IsCiBuild>
    <IsCiBuild Condition="'$(GITHUB_ACTIONS)' == 'true'">true</IsCiBuild>
    <IsReleaseBuild>false</IsReleaseBuild>
    <IsReleaseBuild Condition="'$(IsCiBuild)' == 'true' Or '$(Configuration)' == 'Release'">true</IsReleaseBuild>
    <_NpmRestoreCommand>npm install --no-fund</_NpmRestoreCommand>
    <_NpmRestoreCommand Condition="'$(IsCiBuild)' == 'true'">npm ci --no-fund --no-audit --prefer-offline</_NpmRestoreCommand>
    <_NpmBuildCommand>npm run build</_NpmBuildCommand>
    <_NpmBuildCommand Condition="'$(IsCiBuild)' == 'true'">npm run build:release</_NpmBuildCommand>
  </PropertyGroup>

  <Target Name="RestoreClient" Inputs="Client\package.json;Client\package-lock.json" Outputs="Client\node_modules\.package-lock.json">
    <Message Text="[Articulate] Restoring NPM packages with command: $(_NpmRestoreCommand)..." Importance="high" />
    <Exec Command="$(_NpmRestoreCommand)" WorkingDirectory="Client" />
  </Target>

  <!--This does not always detect changes in development, clean and rebuild or build client yourself.-->
  <Target Name="BuildClient" DependsOnTargets="RestoreClient" BeforeTargets="AssignTargetPaths" Inputs="@(ClientAssetsInput)" Outputs="$(IntermediateOutputPath)client.complete.txt">
    <Message Importance="high" Text="[Articulate] Building Client with NPM command: $(_FinalBuildCommand)" />
    <!--Allow build to continue with warning if not CI we may be working on API/Client changes.-->
    <Exec Command="$(_NpmBuildCommand)" WorkingDirectory="Client" Condition="'$(IsReleaseBuild)' == 'false'" ContinueOnError="true">
      <Output TaskParameter="ExitCode" PropertyName="ClientBuildExitCode" />
    </Exec>
    <!--Fail build if client build to fails for CI or Relase build-->
    <Exec Command="$(_NpmBuildCommand)" WorkingDirectory="Client" Condition="'$(IsReleaseBuild)' == 'true'">
      <Output TaskParameter="ExitCode" PropertyName="ClientBuildExitCode" />
    </Exec>
    <Warning Condition="'$(IsReleaseBuild)' == 'false' AND '$(ClientBuildExitCode)' != '0'" Text="[Articulate] The BackOffice client-side build failed, check the Client project to resolve. The .NET build will continue." />
    <Error Condition="'$(IsReleaseBuild)' == 'true' AND '$(ClientBuildExitCode)' != '0'" Text="[Articulate] The BackOffice client-side build FAILED, check the Client project to resolve. .NET build aborted." />
    <ItemGroup>
      <_ClientAssetsBuildOutput Include="wwwroot\App_Plugins\**" />
    </ItemGroup>
    <WriteLinesToFile File="$(IntermediateOutputPath)client.complete.txt" Lines="@(_ClientAssetsBuildOutput)" Overwrite="true" />
  </Target>

  <ItemGroup>
    <Folder Include="wwwroot\" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\..\LICENSE">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </None>
    <None Include="..\..\README.md">
      <Pack>true</Pack>
      <PackagePath>\</PackagePath>
    </None>
  </ItemGroup>

</Project>
