{
  "name": "articulate-backoffice",
  "private": true,
  "version": "6.0.0-g7d1e78c87c",
  "type": "module",
  "description": "Articulate BackOffice extension",
  "engines": {
    "node": ">=22",
    "npm": ">=10.9.2"
  },
  "keywords": [
    "blog",
    "umbraco",
    "backoffice",
    "lit",
    "web components"
  ],
  "author": "Articulate",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build --mode development",
    "build:release": "tsc && vite build --mode production",
    "preview": "vite preview",
    "watch": "vite build --watch",
    "lint:errors": "npm run lint -- --quiet",
    "lint:fix": "npm run lint -- --fix",
    "lint": "eslint src",
    "check": "tsc --noEmit",
    "generate:api": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 node ./scripts/generate-api.js https://localhost:44366/umbraco/swagger/articulate/swagger.json ./src/api --excludeTags 'Markdown Editor'"
  },
  "dependenciesComments": {
    "monaco-editor": "Articulate Markdown Editor property editor (not the mobile markdown editor), only required until Umbraco Core editor supports better markdown to HTML processing; see https://github.com/umbraco/Umbraco-CMS/issues/19500"
  },
  "dependencies": {
    "monaco-editor": "^0.52.2"
  },
  "devDependencies": {
    "@eslint/compat": "^1.3.1",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.32.0",
    "@hey-api/openapi-ts": "^0.80.2",
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "@umbraco-cms/backoffice": "^15.4.4",
    "chalk": "~5.5.0",
    "cross-env": "^10.0.0",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-lit": "^2.1.1",
    "eslint-plugin-lit-a11y": "^5.1.1",
    "eslint-plugin-local-rules": "^3.0.2",
    "eslint-plugin-prettier": "^5.5.3",
    "eslint-plugin-wc": "^3.0.1",
    "fs-extra": "^11.3.0",
    "globals": "^16.3.0",
    "node-fetch": "~3.3.2",
    "prettier": "^3.6.2",
    "typescript": "~5.9.2",
    "vite": "^7.0.6",
    "vite-tsconfig-paths": "~5.1.4"
  }
}
