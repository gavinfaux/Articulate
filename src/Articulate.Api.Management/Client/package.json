{
  "name": "articulate-backoffice",
  "private": true,
  "version": "6.0.0-g98ebf60231",
  "type": "module",
  "description": "Articulate BackOffice extension",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10.20.0"
  },
  "packageManager": "pnpm@10.24.0+sha512.01ff8ae71b4419903b65c60fb2dc9d34cf8bb6e06d03bde112ef38f7a34d6904c424ba66bea5cdcf12890230bf39f9580473140ed9c946fef328b6e5238a345a",
  "keywords": [
    "blog",
    "umbraco",
    "backoffice",
    "lit",
    "web components"
  ],
  "author": "Articulate",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build --mode development",
    "build:release": "tsc && vite build --mode production",
    "preview": "vite preview",
    "watch": "vite build --watch",
    "lint:errors": "pnpm run lint --quiet",
    "lint:fix": "pnpm run lint --fix",
    "lint": "eslint src",
    "check": "tsc --noEmit",
    "lint-staged": "lint-staged",
    "gitleaks:protect": "gitleaks protect --staged --no-banner --redact",
    "prepare": "node ./scripts/install-husky.mjs",
    "generate:api": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 node ./scripts/generate-api.js https://localhost:44366/umbraco/swagger/articulate/swagger.json ./src/api --excludeTags 'Markdown Editor'",
    "clean": "pnpm dlx rimraf node_modules pnpm-lock.yaml mise.lock"
  },
  "dependenciesComments": {
    "monaco-editor": "Articulate Markdown Editor property editor (not the mobile markdown editor), only required until Umbraco Core editor supports better markdown to HTML processing; see https://github.com/umbraco/Umbraco-CMS/issues/19500"
  },
  "dependencies": {
    "monaco-editor": "^0.52.2"
  },
  "devDependencies": {
    "@eslint/compat": "^1.4.1",
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.1",
    "@hey-api/client-fetch": "^0.12.0",
    "@hey-api/openapi-ts": "^0.72.2",
    "@types/fs-extra": "^11.0.4",
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "@umbraco-cms/backoffice": "^15.4.4",
    "chalk": "^5.6.2",
    "cross-env": "^10.1.0",
    "esbuild": "^0.25.12",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-lit": "^2.1.1",
    "eslint-plugin-lit-a11y": "^5.1.1",
    "eslint-plugin-local-rules": "^3.0.2",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-wc": "^3.0.2",
    "fs-extra": "^11.3.2",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lightningcss": "1.30.2",
    "lint-staged": "^15.5.2",
    "node-fetch": "~3.3.2",
    "prettier": "^3.7.4",
    "terser": "^5.44.1",
    "typescript": "~5.9.3",
    "vite": "^7.2.6",
    "vite-tsconfig-paths": "~5.1.4"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "pnpm exec eslint --max-warnings=0 --no-warn-ignored"
    ]
  }
}
