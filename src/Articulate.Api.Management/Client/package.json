{
  "name": "articulate-backoffice",
  "private": true,
  "version": "6.0.0-g174ba6b9a5",
  "type": "module",
  "description": "Articulate BackOffice extension",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10.17.0"
  },
  "packageManager": "pnpm@10.19.0+sha512.c9fc7236e92adf5c8af42fd5bf1612df99c2ceb62f27047032f4720b33f8eacdde311865e91c411f2774f618d82f320808ecb51718bfa82c060c4ba7c76a32b8",
  "keywords": [
    "blog",
    "umbraco",
    "backoffice",
    "lit",
    "web components"
  ],
  "author": "Articulate",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build --mode development",
    "build:release": "tsc && vite build --mode production",
    "preview": "vite preview",
    "watch": "vite build --watch",
    "lint:errors": "pnpm run lint -- --quiet",
    "lint:fix": "pnpm run lint -- --fix",
    "lint": "eslint src",
    "check": "tsc --noEmit",
    "generate:api": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 node ./scripts/generate-api.js https://localhost:44366/umbraco/swagger/articulate/swagger.json ./src/api --excludeTags 'Markdown Editor'",
    "clean": "npx rimraf node_modules pnpm-lock.yaml"
  },
  "dependenciesComments": {
    "monaco-editor": "Articulate Markdown Editor property editor (not the mobile markdown editor), only required until Umbraco Core editor supports better markdown to HTML processing; see https://github.com/umbraco/Umbraco-CMS/issues/19500"
  },
  "dependencies": {
    "monaco-editor": "^0.52.2"
  },
  "devDependencies": {
    "@eslint/compat": "^1.4.0",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.38.0",
    "@hey-api/client-fetch": "^0.12.0",
    "@hey-api/openapi-ts": "^0.72.2",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "@umbraco-cms/backoffice": "^15.4.4",
    "chalk": "^5.6.2",
    "cross-env": "^10.1.0",
    "esbuild": "^0.25.11",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-lit": "^2.1.1",
    "eslint-plugin-lit-a11y": "^5.1.1",
    "eslint-plugin-local-rules": "^3.0.2",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-wc": "^3.0.2",
    "fs-extra": "^11.3.2",
    "globals": "^16.4.0",
    "lightningcss": "1.30.2",
    "node-fetch": "~3.3.2",
    "prettier": "^3.6.2",
    "terser": "^5.44.0",
    "typescript": "~5.9.3",
    "vite": "^7.1.12",
    "vite-tsconfig-paths": "~5.1.4"
  }
}
