#!/usr/bin/env sh

set -eu

if [ "${HUSKY:-1}" = "0" ]; then
  exit 0
fi

REPO_ROOT="$(cd "$(dirname -- "$0")/.." && pwd)"
CLIENT_DIR="$REPO_ROOT/src/Articulate.Api.Management/Client"

if ! command -v pnpm >/dev/null 2>&1; then
  echo "pnpm is required for the pre-commit checks (install pnpm 10.17+)." >&2
  exit 1
fi

pnpm --dir "$CLIENT_DIR" run lint-staged

if git diff --cached --name-only | grep -qE '^src/Articulate.Api.Management/Client/src/'; then
  echo "Detected staged client source changes. Building client bundle..."
  pnpm --dir "$CLIENT_DIR" run build
fi

if command -v gitleaks >/dev/null 2>&1; then
  pnpm --dir "$CLIENT_DIR" run gitleaks:protect
else
  echo "gitleaks is required for secret scanning. Install from https://github.com/gitleaks/gitleaks/releases." >&2
  exit 1
fi
