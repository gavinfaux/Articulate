{
  "$schema": "appsettings-schema.json",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "Console"
            }
          ]
        }
      }
    ]
  },
  "Umbraco": {
    "CMS": {
      "Hosting": {
        "Debug": false
      },
      "Global": {
        "Id": "1bf3cfb0-a911-463d-8ae7-6125058b810a",
        "SanitizeTinyMce": true,
        "InstallMissingDatabase": true,
        "DisableElectionForSingleServer": true
      },
      "Content": {
        "AllowEditInvariantFromNonDefault": true,
        "ContentVersionCleanupPolicy": {
          "EnableCleanup": true
        }
      },
      "DeliveryApi": {
        "Enabled": true
      },
      "Unattended": {
        "InstallUnattended": true,
        "UnattendedUserName": "admin",
        "UnattendedUserEmail": "admin@example.com",
        "UnattendedUserPassword": "ChangeMe123!"
      },
      "Security": {
        "BackOfficeHost": "http://localhost:8080",
        "BackOfficeTokenCookie": {
          "SameSite": "Lax"
        }
      },
      "WebRouting": {
        "UmbracoApplicationUrl": "http://localhost:8080/"
      },
      "ModelsBuilder": {
        "ModelsMode": "Nothing"
      }
    }
  },
  "Articulate": {
    "AutoPublishOnStartup": true,
    "ManagementApi": {
      "OpenIddict": {
        "Client": {
          "Enabled": true,
          "ClientId": "umbraco-articulate",
          "DisplayName": "Articulate Markdown Editor",
          "RedirectUris": [
            "http://localhost:8080/a-new/"
          ],
          "PostLogoutRedirectUris": [
            "http://localhost:8080/umbraco/management/api/v1/security/back-office/signout?post_logout_redirect_uri=http%3A%2F%2Flocalhost%3A8080%2F",
            "http://localhost:8080/"
          ]
        }
      }
    }
  },
  "ConnectionStrings": {
    "umbracoDbDSN": "Data Source=|DataDirectory|/Umbraco.sqlite.db;Cache=Shared;Foreign Keys=True;Pooling=True",
    "umbracoDbDSN_ProviderName": "Microsoft.Data.Sqlite"
  }
}
